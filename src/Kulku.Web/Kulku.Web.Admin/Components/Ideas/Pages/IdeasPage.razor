@page "/ideas"

@using Kulku.Application.IdeaBank.Models
@using Kulku.Web.Admin.Components.Ideas.Components

@attribute [Authorize]

<PageTitle>@IdeasStrings.PageTitle</PageTitle>

<div class="container-fluid py-4 px-4">
	<div class="d-flex justify-content-between align-items-center mb-3">
		<h3 class="mb-0">💡 @IdeasStrings.Heading</h3>
		<button class="btn btn-primary btn-sm" @onclick="HandleCreateIdea">
			<Icon Kind="IconKind.Plus" Size="16" /> @IdeasStrings.NewIdea
		</button>
	</div>

	@* ── Filters ── *@
	<div class="row g-2 mb-3">
		<div class="col-md-3">
			<input type="text" class="form-control form-control-sm" placeholder="@Strings.Search"
				   @bind="_searchText" @bind:event="oninput" />
		</div>
		<div class="col-md-2">
			<select class="form-select form-select-sm" @bind="_filterDomainId">
				<option value="@Guid.Empty">@IdeasStrings.AllDomains</option>
				@foreach (var d in _domains)
				{
					<option value="@d.Id">@d.Name</option>
				}
			</select>
		</div>
		<div class="col-md-2">
			<select class="form-select form-select-sm" @bind="_filterStatusId">
				<option value="@Guid.Empty">@IdeasStrings.AllStatuses</option>
				@foreach (var s in _statuses)
				{
					<option value="@s.Id">@s.Name</option>
				}
			</select>
		</div>
		<div class="col-md-2">
			<select class="form-select form-select-sm" @bind="_filterPriorityId">
				<option value="@Guid.Empty">@IdeasStrings.AllPriorities</option>
				@foreach (var p in _priorities)
				{
					<option value="@p.Id">@p.Name</option>
				}
			</select>
		</div>
		<div class="col-md-2">
			<select class="form-select form-select-sm" @bind="_filterTagId">
				<option value="@Guid.Empty">@IdeasStrings.AllTags</option>
				@foreach (var t in _tags)
				{
					<option value="@t.Id">@t.Name</option>
				}
			</select>
		</div>
	</div>

	@* ── Ideas List ── *@
	@{
		var filtered = FilteredIdeas;
	}

	@if (filtered.Count == 0)
	{
		<div class="text-muted text-center py-4">
			@(_ideas.Count == 0 ? IdeasStrings.NoIdeas : IdeasStrings.NoMatch)
		</div>
	}
	else
	{
		@foreach (var idea in filtered)
		{
			<IdeaCard Idea="@idea" OnEdit="HandleEditIdea" OnDelete="HandleDeleteIdea" />
		}
	}

	@* ── Tags Section (collapsible) ── *@
	<div class="mt-4">
		<div class="d-flex align-items-center gap-2 mb-2 cursor-pointer" @onclick="() => _tagsExpanded = !_tagsExpanded">
			<Icon Kind="@(_tagsExpanded ? IconKind.ChevronDown : IconKind.ChevronRight)" Size="16" />
			<h5 class="mb-0">@Strings.Tags</h5>
			<span class="badge bg-secondary">@_tags.Count</span>
		</div>

		@if (_tagsExpanded)
		{
			<div class="mb-2">
				<button class="btn btn-outline-primary btn-sm" @onclick="HandleCreateTag">
					<Icon Kind="IconKind.Plus" Size="14" /> @IdeasStrings.NewTag
				</button>
			</div>

			@if (_tags.Count == 0)
			{
				<p class="text-muted">@IdeasStrings.NoTags</p>
			}
			else
			{
				@foreach (var tag in _tags)
				{
					<IdeaTagCard Tag="@tag" OnEdit="HandleEditTag" OnDelete="HandleDeleteTag" />
				}
			}
		}
	</div>
</div>

@* ── Modals ── *@
<IdeaEditModal @ref="_ideaModal"
			   Model="@_editingIdea"
			   Mode="@_ideaMode"
			   Domains="@_domains"
			   Statuses="@_statuses"
			   Priorities="@_priorities"
			   Tags="@_tags"
			   Keywords="@_keywords"
			   OnSave="HandleSaveIdea"
			   OnCancel="CloseIdeaEditor"
			   IsSaving="@_ideaSaving"
			   ErrorMessage="@_ideaError" />

<IdeaTagEditModal @ref="_tagModal"
				  Model="@_editingTag"
				  Mode="@_tagMode"
				  OnSave="HandleSaveTag"
				  OnCancel="CloseTagEditor"
				  IsSaving="@_tagSaving"
				  ErrorMessage="@_tagError" />
