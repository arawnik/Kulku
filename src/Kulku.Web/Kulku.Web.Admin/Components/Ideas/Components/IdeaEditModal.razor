@using System.ComponentModel.DataAnnotations
@using Kulku.Application.IdeaBank.Models
@using Kulku.Application.Projects.Models
@using SoulNETLib.Clean.Domain

<ModalDialog Visible="@(_form != null)"
			 Title="@(Mode == ModalMode.Create ? IdeasStrings.Idea_CreateModal : IdeasStrings.Idea_EditModal)"
			 Size="ModalSize.Large"
			 OnClose="OnCancel">
	<ChildContent>
		@if (ErrorMessage is not null)
		{
			<div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
		}
		@if (_form != null)
		{
			<EditForm EditContext="@_editContext">
				<DataAnnotationsValidator />
				<ServerValidation @ref="_serverValidation" />

				<div class="mb-3">
					<label class="form-label">@Strings.Title</label>
					<InputText @bind-Value="_form.Title" class="form-control" disabled="@IsSaving"
							   placeholder="A short, descriptive title" />
					<ValidationMessage For="@(() => _form.Title)" />
				</div>

				<div class="mb-3">
					<label class="form-label">@Strings.Summary</label>
					<InputText @bind-Value="_form.Summary" class="form-control" disabled="@IsSaving"
							   placeholder="@IdeasStrings.SummaryPlaceholder" />
				</div>

				<div class="mb-3">
					<MarkdownEditor @bind-Value="_form.Description"
									Label="Description"
									Rows="5"
									MinHeight="5"
									Disabled="@IsSaving"
									Placeholder="Detailed notes (markdown supported)" />
				</div>

				<div class="row mb-3">
					<div class="col-md-4">
						<label class="form-label">@Strings.Domain</label>
						<InputSelect @bind-Value="_form.DomainId" class="form-select" disabled="@IsSaving">
							@foreach (var domain in Domains)
							{
								<option value="@domain.Id">@domain.Name</option>
							}
						</InputSelect>
						<ValidationMessage For="@(() => _form.DomainId)" />
					</div>
					<div class="col-md-4">
						<label class="form-label">@Strings.Status</label>
						<InputSelect @bind-Value="_form.StatusId" class="form-select" disabled="@IsSaving">
							@foreach (var status in Statuses)
							{
								<option value="@status.Id">@status.Name</option>
							}
						</InputSelect>
					</div>
					<div class="col-md-4">
						<label class="form-label">@Strings.Priority</label>
						<InputSelect @bind-Value="_form.PriorityId" class="form-select" disabled="@IsSaving">
							@foreach (var priority in Priorities)
							{
								<option value="@priority.Id">@priority.Name</option>
							}
						</InputSelect>
					</div>
				</div>

				@if (Tags.Count > 0)
				{
					<div class="mb-3">
						<label class="form-label">@Strings.Tags</label>
						<div class="d-flex flex-wrap gap-2">
							@foreach (var tag in Tags)
							{
								var isSelected = _form.SelectedTagIds.Contains(tag.Id);
								<button type="button"
										class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
										disabled="@IsSaving"
										@onclick="() => ToggleTag(tag.Id)">
									@tag.Name
								</button>
							}
						</div>
					</div>
				}

				@if (Keywords.Count > 0)
				{
					<div class="mb-3">
						<label class="form-label">@Strings.Keywords</label>
						@foreach (var group in Keywords.GroupBy(k => k.Type).OrderBy(g => g.Key))
						{
							<div class="mb-2">
								<small class="text-muted fw-semibold">@group.Key</small>
								<div class="d-flex flex-wrap gap-1 mt-1">
									@foreach (var kw in group)
									{
										var isSelected = _form.SelectedKeywordIds.Contains(kw.Id);
										<button type="button"
												class="btn btn-sm @(isSelected ? "btn-success" : "btn-outline-secondary")"
												disabled="@IsSaving"
												@onclick="() => ToggleKeyword(kw.Id)">
											@kw.Name
										</button>
									}
								</div>
							</div>
						}
					</div>
				}
			</EditForm>
		}
	</ChildContent>
	<FooterContent>
		<button type="button" class="btn btn-secondary"
				@onclick="OnCancel" disabled="@IsSaving">
			@Strings.Cancel
		</button>
		<button type="button" class="btn btn-primary"
				@onclick="HandleSubmit" disabled="@IsSaving">
			@if (IsSaving)
			{
				<span class="spinner-border spinner-border-sm me-1"></span>
				<span>@Strings.Saving</span>
			}
			else
			{
				<span>@(Mode == ModalMode.Create ? Strings.Create : Strings.SaveChanges)</span>
			}
		</button>
	</FooterContent>
</ModalDialog>
