@using System.ComponentModel.DataAnnotations
@using Kulku.Application.IdeaBank.Models
@using SoulNETLib.Clean.Domain

<ModalDialog Visible="@(_form != null)"
			 Title="@(Mode == ModalMode.Create ? IdeasStrings.Tag_CreateModal : IdeasStrings.Tag_EditModal)"
			 Size="ModalSize.Default"
			 OnClose="OnCancel">
	<ChildContent>
		@if (ErrorMessage is not null)
		{
			<div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
		}
		@if (_form != null)
		{
			<EditForm EditContext="@_editContext">
				<DataAnnotationsValidator />
				<ServerValidation @ref="_serverValidation" />

				<div class="mb-3">
					<label class="form-label">@Strings.Name</label>
					<InputText @bind-Value="_form.Name" class="form-control" disabled="@IsSaving"
							   placeholder="e.g. AI/ML, Architecture, .NET" />
					<ValidationMessage For="@(() => _form.Name)" />
				</div>

				<div class="mb-3">
					<label class="form-label">@Strings.Color (@Strings.Optional)</label>
					<div class="d-flex align-items-center gap-2">
						<input type="color" class="form-control form-control-color"
							   value="@(_form.ColorHex ?? "#6c757d")"
							   @onchange="e => _form.ColorHex = e.Value?.ToString()"
							   disabled="@IsSaving" />
						<InputText @bind-Value="_form.ColorHex" class="form-control" disabled="@IsSaving"
								   placeholder="#6610f2" style="max-width:8rem" />
						@if (!string.IsNullOrWhiteSpace(_form.ColorHex))
						{
							<button type="button" class="btn btn-sm btn-outline-secondary"
									@onclick="() => _form.ColorHex = null" disabled="@IsSaving">
								Clear
							</button>
						}
					</div>
				</div>
			</EditForm>
		}
	</ChildContent>
	<FooterContent>
		<button type="button" class="btn btn-secondary"
				@onclick="OnCancel" disabled="@IsSaving">
			@Strings.Cancel
		</button>
		<button type="button" class="btn btn-primary"
				@onclick="HandleSubmit" disabled="@IsSaving">
			@if (IsSaving)
			{
				<span class="spinner-border spinner-border-sm me-1"></span>
				<span>@Strings.Saving</span>
			}
			else
			{
				<span>@(Mode == ModalMode.Create ? Strings.Create : Strings.SaveChanges)</span>
			}
		</button>
	</FooterContent>
</ModalDialog>
