@using Kulku.Application.IdeaBank.Models

<div class="card mb-2">
	<div class="card-body py-2 px-3">
		<div class="d-flex justify-content-between align-items-start">
			<div class="flex-grow-1">
				<small class="text-muted">@Note.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
				<div class="mt-1">
					<MarkdownView Content="@Note.Content" />
				</div>
			</div>
			<div class="ms-2 flex-shrink-0">
				@if (!_confirmDelete)
				{
					<button class="btn btn-sm btn-outline-danger" title="Delete note"
							@onclick="() => _confirmDelete = true">
						<Icon Kind="IconKind.Trash" Size="14" />
					</button>
				}
				else
				{
					<button class="btn btn-sm btn-danger" title="Confirm delete"
							@onclick="() => OnDelete.InvokeAsync(Note.Id)">
						<Icon Kind="IconKind.Check" Size="14" />
					</button>
					<button class="btn btn-sm btn-outline-secondary" title="Cancel"
							@onclick="() => _confirmDelete = false">
						✕
					</button>
				}
			</div>
		</div>
	</div>
</div>

@code {
	[Parameter, EditorRequired]
	public IdeaNoteModel Note { get; set; } = null!;

	[Parameter]
	public EventCallback<Guid> OnDelete { get; set; }

	private bool _confirmDelete;
}
