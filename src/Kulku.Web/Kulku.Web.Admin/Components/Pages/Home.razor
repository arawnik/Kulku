@page "/"
@using Kulku.Application.Contacts.Models
@using Kulku.Application.IdeaBank.Models
@using Kulku.Application.Network.Models
@using Kulku.Domain.Contacts
@using Kulku.Domain.Network
@using Kulku.Web.Admin.Components.Network.Components
@using Kulku.Web.Admin.Options

@inject IOptions<ManagementOptions> ManagementOptions

<AuthorizeView>
	<Authorized>
		<PageTitle>Dashboard — Kulku Admin</PageTitle>

		<div class="container-fluid py-4">

			@* ── Header ── *@
			<div class="mb-4">
				<h1 class="h3 mb-1">Dashboard</h1>
				<div class="text-muted">Welcome back, @context.User.Identity?.Name</div>
			</div>

			@* ── KPI Cards ── *@
			<div class="row g-3 mb-4">
				<div class="col-6 col-lg-3">
					<InfoCard Title="Inbox"
							  BadgeCount="_inboxNewCount"
							  BadgeText="new"
							  BadgeColor="@(_inboxNewCount > 0 ? "danger" : "secondary")"
							  Description="Unread contact requests" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="Network"
							  BadgeCount="_networkCount"
							  BadgeText="companies"
							  BadgeColor="primary"
							  Description="Tracked relationships" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="Idea Bank"
							  BadgeCount="_ideaCount"
							  BadgeText="ideas"
							  BadgeColor="info"
							  Description="In the idea bank" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="Portfolio"
							  BadgeCount="_projectCount"
							  BadgeText="projects"
							  BadgeColor="success"
							  Description="Showcase projects" />
				</div>
			</div>

			@* ── Row 2: Recent Requests + Network Attention ── *@
			<div class="row g-3 mb-4">
				<div class="col-12 col-xl-8">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<div>
								<strong>
									<Icon Kind="IconKind.Envelope" Size="16" CssClass="me-1" />Recent Requests
								</strong>
								<div class="text-muted small">Latest new contact requests</div>
							</div>
							<NavLink href="inbox" class="btn btn-sm btn-outline-secondary text-decoration-none">
								View all
							</NavLink>
						</div>
						<div class="card-body p-2">
							@if (_recentRequests.Count == 0)
							{
								<div class="text-muted text-center py-3">
									<Icon Kind="IconKind.Check" Size="20" CssClass="me-1 text-success" />
									No new requests — inbox is clear.
								</div>
							}
							else
							{
								<div class="list-group list-group-flush">
									@foreach (var r in _recentRequests)
									{
										<a href="inbox" class="list-group-item list-group-item-action px-3 py-2">
											<div class="d-flex justify-content-between align-items-start">
												<div class="me-2">
													<div class="fw-semibold small">@r.Name</div>
													<div class="text-muted small text-truncate" style="max-width: 400px;">@r.Subject</div>
												</div>
												<small class="text-muted text-nowrap">@r.Timestamp.ToString("MMM dd")</small>
											</div>
										</a>
									}
								</div>
							}
						</div>
					</div>
				</div>

				<div class="col-12 col-xl-4">
					<div class="card shadow-sm h-100">
						<div class="card-header">
							<strong>
								<Icon Kind="IconKind.ExclamationTriangle" Size="16" CssClass="me-1" />Attention Needed
							</strong>
							<div class="text-muted small">Overdue actions &amp; cold relationships</div>
						</div>
						<div class="card-body">
							@if (_overdueActions.Count == 0 && _coldRelationships.Count == 0)
							{
								<div class="text-center py-3">
									<div class="text-success mb-2">
										<Icon Kind="IconKind.Check" Size="24" />
									</div>
									<div class="text-muted">All relationships are on track.</div>
								</div>
							}
							else
							{
								@if (_overdueActions.Count > 0)
								{
									<div class="mb-3">
										<div class="d-flex align-items-center gap-2 mb-2">
											<span class="badge text-bg-danger">Overdue</span>
											<small class="text-muted">@_overdueActions.Count action(s)</small>
										</div>
										<div class="list-group list-group-flush">
											@foreach (var item in _overdueActions)
											{
												<a href="/network/companies/@item.CompanyId" class="list-group-item list-group-item-action px-0 py-1">
													<div class="d-flex justify-content-between align-items-start">
														<div class="fw-semibold small">@item.CompanyName</div>
														<span class="badge text-bg-danger">@item.DaysCount d</span>
													</div>
													<div class="text-muted small text-truncate">@item.Detail</div>
												</a>
											}
										</div>
									</div>
								}

								@if (_coldRelationships.Count > 0)
								{
									<div>
										<div class="d-flex align-items-center gap-2 mb-2">
											<span class="badge text-bg-warning">Going cold</span>
											<small class="text-muted">@_coldRelationships.Count relationship(s)</small>
										</div>
										<div class="list-group list-group-flush">
											@foreach (var item in _coldRelationships)
											{
												<a href="/network/companies/@item.CompanyId" class="list-group-item list-group-item-action px-0 py-1">
													<div class="fw-semibold small">@item.CompanyName</div>
													<div class="text-muted small">@item.Detail</div>
												</a>
											}
										</div>
									</div>
								}
							}
						</div>
					</div>
				</div>
			</div>

			@* ── Row 3: Recent Ideas + Pipeline Summary ── *@
			<div class="row g-3 mb-4">
				<div class="col-12 col-xl-8">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<div>
								<strong>
									<Icon Kind="IconKind.Journal" Size="16" CssClass="me-1" />Recent Ideas
								</strong>
								<div class="text-muted small">Recently updated ideas</div>
							</div>
							<NavLink href="ideas" class="btn btn-sm btn-outline-secondary text-decoration-none">
								View all
							</NavLink>
						</div>
						<div class="card-body p-2">
							@if (_recentIdeas.Count == 0)
							{
								<div class="text-muted text-center py-3">No ideas yet.</div>
							}
							else
							{
								<div class="list-group list-group-flush">
									@foreach (var idea in _recentIdeas)
									{
										<a href="ideas" class="list-group-item list-group-item-action px-3 py-2">
											<div class="d-flex justify-content-between align-items-start">
												<div class="me-2">
													<div class="d-flex align-items-center gap-2">
														<span class="fw-semibold small">@idea.Title</span>
														<span class="badge @idea.StatusStyle">@idea.StatusName</span>
														<span class="badge @idea.PriorityStyle">@idea.PriorityName</span>
													</div>
													@if (!string.IsNullOrWhiteSpace(idea.Summary))
													{
														<div class="text-muted small text-truncate" style="max-width: 500px;">@idea.Summary</div>
													}
												</div>
												<small class="text-muted text-nowrap">@idea.UpdatedAt.ToString("MMM dd")</small>
											</div>
										</a>
									}
								</div>
							}
						</div>
					</div>
				</div>

				<div class="col-12 col-xl-4">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<strong>
								<Icon Kind="IconKind.Kanban" Size="16" CssClass="me-1" />Pipeline
							</strong>
							<NavLink href="network" class="btn btn-sm btn-outline-secondary text-decoration-none">
								Details
							</NavLink>
						</div>
						<div class="card-body">
							<div class="d-flex flex-wrap gap-2 mb-3">
								@foreach (var stage in Enum.GetValues<CompanyStage>())
								{
									var count = _companies.Count(c => c.Stage == stage);
									<NavLink href="network/companies" class="text-decoration-none">
										<span class="badge @NetworkCompanyCard.StageBadgeClass(stage)">
											@NetworkCompanyCard.StageLabel(stage) @count
										</span>
									</NavLink>
								}
							</div>

							@{
								var latestInteraction = _allInteractions
									.OrderByDescending(i => i.Date)
									.FirstOrDefault();
							}

							@if (latestInteraction is not null)
							{
								<hr class="my-2" />
								<div class="small text-muted mb-1">Latest activity</div>
								<div class="d-flex justify-content-between align-items-start">
									<div>
										<div class="fw-semibold small">@latestInteraction.CompanyName</div>
										<div class="text-muted small text-truncate" style="max-width: 250px;">@latestInteraction.Summary</div>
									</div>
									<small class="text-muted text-nowrap">@latestInteraction.Date.ToString("MMM dd")</small>
								</div>
							}
							else
							{
								<div class="text-muted small text-center py-2">No interactions yet.</div>
							}
						</div>
					</div>
				</div>
			</div>

			@* ── Row 4: CV Snapshot ── *@
			<div class="card shadow-sm">
				<div class="card-header d-flex justify-content-between align-items-center">
					<div>
						<strong>
							<Icon Kind="IconKind.FileEarmarkPerson" Size="16" CssClass="me-1" />CV Overview
						</strong>
						@if (_introduction is not null && !string.IsNullOrWhiteSpace(_introduction.Tagline))
						{
							<div class="text-muted small">@_introduction.Tagline</div>
						}
					</div>
					<NavLink href="cv" class="btn btn-sm btn-outline-secondary text-decoration-none">
						Manage CV
					</NavLink>
				</div>
				<div class="card-body py-3">
					<div class="d-flex flex-wrap gap-4">
						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Briefcase" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_experienceCount</span>
							<span class="text-muted small">experience</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Mortarboard" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_educationCount</span>
							<span class="text-muted small">education</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Folder" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_projectCount</span>
							<span class="text-muted small">projects</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Tags" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_keywordCount</span>
							<span class="text-muted small">keywords</span>
						</div>
					</div>
				</div>
			</div>

		</div>
	</Authorized>
	<NotAuthorized>
		<PageTitle>Kulku Admin</PageTitle>

		<div class="container py-5">
			<div class="text-center mb-5">
				<h1 class="display-5 fw-bold mb-3">Kulku Admin</h1>
				<p class="lead text-muted mx-auto" style="max-width: 600px;">
					A personal management dashboard for maintaining your professional
					portfolio, CV content, project showcases, and developer workflow.
				</p>

				@if (!ManagementOptions.Value.RegistrationEnabled && !string.IsNullOrEmpty(ManagementOptions.Value.ContactUrl))
				{
					<br />
					<div class="text-center">
						<h4 class="fw-semibold mb-3">Want to get in touch?</h4>
						<p class="text-muted mx-auto" style="max-width: 500px;">
							Registration is currently closed. If you'd like to reach out,
							you can send me a message through my contact form.
						</p>
						<a href="@ManagementOptions.Value.ContactUrl"
							   target="_blank"
							   rel="noopener noreferrer"
							   class="btn btn-outline-primary mt-2">
							Send a message
						</a>
					</div>
				}
				else
				{
					<br />
					<div class="d-flex justify-content-center gap-3 mt-3">
						<a href="Account/Login" class="btn btn-primary btn-lg">
							<Icon Kind="IconKind.PersonBadge" Size="20" />
							Sign in
						</a>
						<a href="Account/Register" class="btn btn-outline-primary btn-lg">
							<Icon Kind="IconKind.Person" Size="20" />
							Register
						</a>
					</div>
				}
			</div>

			<hr class="my-5" />

			<div class="row g-4">
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.FileEarmarkPerson" Size="36" />
							</div>
							<h5 class="card-title">CV Management</h5>
							<p class="card-text text-muted small">
								Manage your introduction, education, work experience, and skill keywords
								across multiple languages.
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Folder" Size="36" />
							</div>
							<h5 class="card-title">Project Portfolio</h5>
							<p class="card-text text-muted small">
								Showcase your projects with descriptions, images, and links.
								Content feeds directly to the public site.
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Journal" Size="36" />
							</div>
							<h5 class="card-title">Idea Bank</h5>
							<p class="card-text text-muted small">
								Capture and organize project ideas, feature requests, and inspiration
								for future work.
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Lightbulb" Size="36" />
							</div>
							<h5 class="card-title">Network</h5>
							<p class="card-text text-muted small">
								Track companies, interactions, and networking activity
								to stay on top of your professional outreach.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</NotAuthorized>
</AuthorizeView>
