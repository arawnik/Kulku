@page "/"
@using Kulku.Application.Contacts.Models
@using Kulku.Application.IdeaBank.Models
@using Kulku.Application.Network.Models
@using Kulku.Domain.Contacts
@using Kulku.Domain.Network
@using Kulku.Web.Admin.Components.Network.Components
@using Kulku.Web.Admin.Options

@inject IOptions<ManagementOptions> ManagementOptions

<AuthorizeView>
	<Authorized>
		<PageTitle>@LayoutStrings.Dashboard_PageTitle</PageTitle>

		<div class="container-fluid py-4">

			@* ── Header ── *@
			<div class="mb-4">
				<h1 class="h3 mb-1">@LayoutStrings.Dashboard_Heading</h1>
				<div class="text-muted">@LayoutStrings.Dashboard_Welcome @context.User.Identity?.Name</div>
			</div>

			@* ── KPI Cards ── *@
			<div class="row g-3 mb-4">
				<div class="col-6 col-lg-3">
					<InfoCard Title="@LayoutStrings.Dashboard_Inbox"
							  BadgeCount="_inboxNewCount"
							  BadgeText="@LayoutStrings.Dashboard_New"
							  BadgeColor="@(_inboxNewCount > 0 ? "danger" : "secondary")"
							  Description="@LayoutStrings.Dashboard_UnreadRequests" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="@LayoutStrings.Dashboard_Network"
							  BadgeCount="_networkCount"
							  BadgeText="@LayoutStrings.Dashboard_Companies"
							  BadgeColor="primary"
							  Description="@LayoutStrings.Dashboard_TrackedRelationships" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="@LayoutStrings.Dashboard_IdeaBank"
							  BadgeCount="_ideaCount"
							  BadgeText="@LayoutStrings.Dashboard_Ideas"
							  BadgeColor="info"
							  Description="@LayoutStrings.Dashboard_InTheIdeaBank" />
				</div>
				<div class="col-6 col-lg-3">
					<InfoCard Title="@LayoutStrings.Dashboard_Portfolio"
							  BadgeCount="_projectCount"
							  BadgeText="@LayoutStrings.Dashboard_Projects"
							  BadgeColor="success"
							  Description="@LayoutStrings.Dashboard_ShowcaseProjects" />
				</div>
			</div>

			@* ── Row 2: Recent Requests + Network Attention ── *@
			<div class="row g-3 mb-4">
				<div class="col-12 col-xl-8">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<div>
								<strong>
									<Icon Kind="IconKind.Envelope" Size="16" CssClass="me-1" />@LayoutStrings.Dashboard_RecentRequests
								</strong>
								<div class="text-muted small">@LayoutStrings.Dashboard_LatestNewRequests</div>
							</div>
							<NavLink href="inbox" class="btn btn-sm btn-outline-secondary text-decoration-none">
								@Strings.ViewAll
							</NavLink>
						</div>
						<div class="card-body p-2">
							@if (_recentRequests.Count == 0)
							{
								<div class="text-muted text-center py-3">
									<Icon Kind="IconKind.Check" Size="20" CssClass="me-1 text-success" />
									@LayoutStrings.Dashboard_NoNewRequests
								</div>
							}
							else
							{
								<div class="list-group list-group-flush">
									@foreach (var r in _recentRequests)
									{
										<a href="inbox" class="list-group-item list-group-item-action px-3 py-2">
											<div class="d-flex justify-content-between align-items-start">
												<div class="me-2">
													<div class="fw-semibold small">@r.Name</div>
													<div class="text-muted small text-truncate" style="max-width: 400px;">@r.Subject</div>
												</div>
												<small class="text-muted text-nowrap">@r.Timestamp.ToString("MMM dd")</small>
											</div>
										</a>
									}
								</div>
							}
						</div>
					</div>
				</div>

				<div class="col-12 col-xl-4">
					<div class="card shadow-sm h-100">
						<div class="card-header">
							<strong>
								<Icon Kind="IconKind.ExclamationTriangle" Size="16" CssClass="me-1" />@LayoutStrings.Dashboard_AttentionNeeded
							</strong>
							<div class="text-muted small">@LayoutStrings.Dashboard_OverdueAndCold</div>
						</div>
						<div class="card-body">
							@if (_overdueActions.Count == 0 && _coldRelationships.Count == 0)
							{
								<div class="text-center py-3">
									<div class="text-success mb-2">
										<Icon Kind="IconKind.Check" Size="24" />
									</div>
									<div class="text-muted">@LayoutStrings.Dashboard_AllOnTrack</div>
								</div>
							}
							else
							{
								@if (_overdueActions.Count > 0)
								{
									<div class="mb-3">
										<div class="d-flex align-items-center gap-2 mb-2">
											<span class="badge text-bg-danger">@LayoutStrings.Dashboard_Overdue</span>
											<small class="text-muted">@_overdueActions.Count @LayoutStrings.Dashboard_Actions</small>
										</div>
										<div class="list-group list-group-flush">
											@foreach (var item in _overdueActions)
											{
												<a href="/network/companies/@item.CompanyId" class="list-group-item list-group-item-action px-0 py-1">
													<div class="d-flex justify-content-between align-items-start">
														<div class="fw-semibold small">@item.CompanyName</div>
														<span class="badge text-bg-danger">@item.DaysCount d</span>
													</div>
													<div class="text-muted small text-truncate">@item.Detail</div>
												</a>
											}
										</div>
									</div>
								}

								@if (_coldRelationships.Count > 0)
								{
									<div>
										<div class="d-flex align-items-center gap-2 mb-2">
											<span class="badge text-bg-warning">@LayoutStrings.Dashboard_GoingCold</span>
											<small class="text-muted">@_coldRelationships.Count @LayoutStrings.Dashboard_Relationships</small>
										</div>
										<div class="list-group list-group-flush">
											@foreach (var item in _coldRelationships)
											{
												<a href="/network/companies/@item.CompanyId" class="list-group-item list-group-item-action px-0 py-1">
													<div class="fw-semibold small">@item.CompanyName</div>
													<div class="text-muted small">@item.Detail</div>
												</a>
											}
										</div>
									</div>
								}
							}
						</div>
					</div>
				</div>
			</div>

			@* ── Row 3: Recent Ideas + Pipeline Summary ── *@
			<div class="row g-3 mb-4">
				<div class="col-12 col-xl-8">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<div>
								<strong>
									<Icon Kind="IconKind.Journal" Size="16" CssClass="me-1" />@LayoutStrings.Dashboard_RecentIdeas
								</strong>
								<div class="text-muted small">@LayoutStrings.Dashboard_RecentlyUpdatedIdeas</div>
							</div>
							<NavLink href="ideas" class="btn btn-sm btn-outline-secondary text-decoration-none">
								@Strings.ViewAll
							</NavLink>
						</div>
						<div class="card-body p-2">
							@if (_recentIdeas.Count == 0)
							{
								<div class="text-muted text-center py-3">@LayoutStrings.Dashboard_NoIdeasYet</div>
							}
							else
							{
								<div class="list-group list-group-flush">
									@foreach (var idea in _recentIdeas)
									{
										<a href="ideas" class="list-group-item list-group-item-action px-3 py-2">
											<div class="d-flex justify-content-between align-items-start">
												<div class="me-2">
													<div class="d-flex align-items-center gap-2">
														<span class="fw-semibold small">@idea.Title</span>
														<span class="badge @idea.StatusStyle">@idea.StatusName</span>
														<span class="badge @idea.PriorityStyle">@idea.PriorityName</span>
													</div>
													@if (!string.IsNullOrWhiteSpace(idea.Summary))
													{
														<div class="text-muted small text-truncate" style="max-width: 500px;">@idea.Summary</div>
													}
												</div>
												<small class="text-muted text-nowrap">@idea.UpdatedAt.ToString("MMM dd")</small>
											</div>
										</a>
									}
								</div>
							}
						</div>
					</div>
				</div>

				<div class="col-12 col-xl-4">
					<div class="card shadow-sm h-100">
						<div class="card-header d-flex justify-content-between align-items-center">
							<strong>
								<Icon Kind="IconKind.Kanban" Size="16" CssClass="me-1" />@NetworkStrings.Pipeline
							</strong>
							<NavLink href="network" class="btn btn-sm btn-outline-secondary text-decoration-none">
								@Strings.Details
							</NavLink>
						</div>
						<div class="card-body">
							<div class="d-flex flex-wrap gap-2 mb-3">
								@foreach (var stage in Enum.GetValues<CompanyStage>())
								{
									var count = _companies.Count(c => c.Stage == stage);
									<NavLink href="network/companies" class="text-decoration-none">
										<span class="badge @NetworkCompanyCard.StageBadgeClass(stage)">
											@NetworkCompanyCard.StageLabel(stage) @count
										</span>
									</NavLink>
								}
							</div>

							@{
								var latestInteraction = _allInteractions
								  .OrderByDescending(i => i.Date)
								  .FirstOrDefault();
							}

							@if (latestInteraction is not null)
							{
								<hr class="my-2" />
								<div class="small text-muted mb-1">@LayoutStrings.Dashboard_LatestActivity</div>
								<div class="d-flex justify-content-between align-items-start">
									<div>
										<div class="fw-semibold small">@latestInteraction.CompanyName</div>
										<div class="text-muted small text-truncate" style="max-width: 250px;">@latestInteraction.Summary</div>
									</div>
									<small class="text-muted text-nowrap">@latestInteraction.Date.ToString("MMM dd")</small>
								</div>
							}
							else
							{
								<div class="text-muted small text-center py-2">@LayoutStrings.Dashboard_NoInteractionsYet</div>
							}
						</div>
					</div>
				</div>
			</div>

			@* ── Row 4: CV Snapshot ── *@
			<div class="card shadow-sm">
				<div class="card-header d-flex justify-content-between align-items-center">
					<div>
						<strong>
							<Icon Kind="IconKind.FileEarmarkPerson" Size="16" CssClass="me-1" />@LayoutStrings.Dashboard_CvOverview
						</strong>
						@if (_introduction is not null && !string.IsNullOrWhiteSpace(_introduction.Tagline))
						{
							<div class="text-muted small">@_introduction.Tagline</div>
						}
					</div>
					<NavLink href="cv" class="btn btn-sm btn-outline-secondary text-decoration-none">
						@LayoutStrings.Dashboard_ManageCv
					</NavLink>
				</div>
				<div class="card-body py-3">
					<div class="d-flex flex-wrap gap-4">
						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Briefcase" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_experienceCount</span>
							<span class="text-muted small">@LayoutStrings.Dashboard_Experience</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Mortarboard" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_educationCount</span>
							<span class="text-muted small">@LayoutStrings.Dashboard_Education</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Folder" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_projectCount</span>
							<span class="text-muted small">@LayoutStrings.Dashboard_Projects</span>
						</div>

						<div class="vr d-none d-md-block"></div>

						<div class="d-flex align-items-baseline gap-2">
							<Icon Kind="IconKind.Tags" Size="16" CssClass="text-muted" />
							<span class="h5 mb-0">@_keywordCount</span>
							<span class="text-muted small">@LayoutStrings.Dashboard_Keywords</span>
						</div>
					</div>
				</div>
			</div>

		</div>
	</Authorized>
	<NotAuthorized>
		<PageTitle>@LayoutStrings.AppTitle</PageTitle>

		<div class="container py-5">
			<div class="text-center mb-5">
				<h1 class="display-5 fw-bold mb-3">@LayoutStrings.AppTitle</h1>
				<p class="lead text-muted mx-auto" style="max-width: 600px;">
					@LayoutStrings.Landing_Description
				</p>

				@if (!ManagementOptions.Value.RegistrationEnabled && !string.IsNullOrEmpty(ManagementOptions.Value.ContactUrl))
				{
					<br />
					<div class="text-center">
						<h4 class="fw-semibold mb-3">@LayoutStrings.Landing_GetInTouch</h4>
						<p class="text-muted mx-auto" style="max-width: 500px;">
							@LayoutStrings.Landing_RegistrationClosed
						</p>
						<a href="@ManagementOptions.Value.ContactUrl"
							   target="_blank"
							   rel="noopener noreferrer"
							   class="btn btn-outline-primary mt-2">
							@LayoutStrings.Landing_SendMessage
						</a>
					</div>
				}
				else
				{
					<br />
					<div class="d-flex justify-content-center gap-3 mt-3">
						<a href="Account/Login" class="btn btn-primary btn-lg">
							<Icon Kind="IconKind.PersonBadge" Size="20" />
							@LayoutStrings.Landing_SignIn
						</a>
						<a href="Account/Register" class="btn btn-outline-primary btn-lg">
							<Icon Kind="IconKind.Person" Size="20" />
							@LayoutStrings.Landing_Register
						</a>
					</div>
				}
			</div>

			<hr class="my-5" />

			<div class="row g-4">
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.FileEarmarkPerson" Size="36" />
							</div>
							<h5 class="card-title">@LayoutStrings.Landing_CvManagement</h5>
							<p class="card-text text-muted small">
								@LayoutStrings.Landing_CvManagementDesc
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Folder" Size="36" />
							</div>
							<h5 class="card-title">@LayoutStrings.Landing_ProjectPortfolio</h5>
							<p class="card-text text-muted small">
								@LayoutStrings.Landing_ProjectPortfolioDesc
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Journal" Size="36" />
							</div>
							<h5 class="card-title">@LayoutStrings.Landing_IdeaBank</h5>
							<p class="card-text text-muted small">
								@LayoutStrings.Landing_IdeaBankDesc
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body text-center">
							<div class="mb-3 text-primary">
								<Icon Kind="IconKind.Lightbulb" Size="36" />
							</div>
							<h5 class="card-title">@LayoutStrings.Landing_Network</h5>
							<p class="card-text text-muted small">
								@LayoutStrings.Landing_NetworkDesc
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</NotAuthorized>
</AuthorizeView>
