@page "/"
@using Kulku.Web.Admin.Components.Developer
@inject CrmProtoStore Store

<PageTitle>CRM Dashboard</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Developer Overview</h1>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <NavLink class="btn btn-sm btn-primary" href="developer">Developer CRM</NavLink>
            <NavLink class="btn btn-sm btn-outline-secondary" href="developer/ideas">Idea Bank</NavLink>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <InfoCard Title="Companies tracked"
                      BadgeCount="@Store.Companies.Count"
                      BadgeText="focus list"
                      BadgeColor="secondary"
                      Description="Keep this small. Quality relationships only." />
        </div>

        <div class="col-6 col-md-3">
            <InfoCard Title="Inbound (90d)"
                      BadgeCount="@InboundTotal"
                      BadgeText="signal"
                      BadgeColor="primary"
                      Description="Channel performance across your funnel." />
        </div>

        <div class="col-6 col-md-3">
            <InfoCard Title="Outbound (90d)"
                      BadgeCount="@OutboundTotal"
                      BadgeText="discipline"
                      BadgeColor="secondary"
                      Description="Selective touches; avoid volume bias." />
        </div>

        <div class="col-6 col-md-3">
            <InfoCard Title="Ideas (active)"
                      BadgeCount="@ActiveIdeasCount"
                      BadgeText="developer zone"
                      BadgeColor="dark"
                      Description="Seeds to validate, not tickets yet." />
        </div>
    </div>
</div>
