@page "/network/loginteraction"
@using Kulku.Application.Network.Models
@using Kulku.Domain.Network
@using Kulku.Web.Admin.Components.Network.Components

@inject NavigationManager Nav

@attribute [Authorize]

<PageTitle>@NetworkStrings.LogInteraction_PageTitle</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">@NetworkStrings.LogInteraction_Heading</h1>
			<div class="text-muted">@NetworkStrings.LogInteraction_Subtitle</div>
		</div>
		<NavLink class="btn btn-sm btn-outline-secondary" href="network">@NetworkStrings.LogInteraction_BackToDashboard</NavLink>
	</div>

	<div class="row g-3">
		<div class="col-12 col-xl-7">
			<div class="card shadow-sm">
				<div class="card-header">
					<strong>@NetworkStrings.LogInteraction_Details</strong>
				</div>
				<div class="card-body">
					<EditForm Model="@Model" OnValidSubmit="@OnSubmit">
						<DataAnnotationsValidator />
						<ValidationSummary />

						<div class="row g-3 mb-3">
							<div class="col-md-4">
								<label class="form-label">@Strings.Direction</label>
								<select class="form-select" @bind="Model.Direction">
									@foreach (var d in Enum.GetValues<InteractionDirection>())
									{
										<option value="@d">@d</option>
									}
								</select>
							</div>

							<div class="col-md-4">
								<label class="form-label">@Strings.Channel</label>
								<select class="form-select" @bind="Model.Channel">
									@foreach (var ch in Enum.GetValues<InteractionChannel>())
									{
										<option value="@ch">@ChannelLabel(ch)</option>
									}
								</select>
							</div>

							<div class="col-md-4">
								<label class="form-label">@Strings.Date</label>
								<input class="form-control" type="date" @bind="Model.Date" />
							</div>
						</div>

						<!-- Company select -->
						<div class="mb-3">
							<label class="form-label">@Strings.Company</label>

							<div class="row g-2">
								<div class="col-md-7">
									<select class="form-select" @onchange="OnCompanyChanged">
										<option value="">@Strings.SelectCompany</option>
										@foreach (var c in _enrolledCompanies.OrderBy(c => c.Name))
										{
											<option value="@c.CompanyId">@c.Name (@c.Region)</option>
										}
									</select>
									<div class="form-text">@NetworkStrings.LogInteraction_SelectCompany</div>
								</div>
							</div>
						</div>

						<!-- Warm intro -->
						<div class="mb-3">
							<div class="form-check">
								<input class="form-check-input" type="checkbox" id="warmIntro" @bind="Model.IsWarmIntro" />
								<label class="form-check-label" for="warmIntro">
									@NetworkStrings.LogInteraction_WarmIntro
								</label>
							</div>

							<div class="row g-2 mt-2">
								<div class="col-md-4">
									<select class="form-select" @bind="Model.ReferredByRelation" disabled="@(!Model.IsWarmIntro)">
										<option value="">—</option>
										<option value="Friend">@NetworkStrings.LogInteraction_Friend</option>
										<option value="Colleague">@NetworkStrings.LogInteraction_Colleague</option>
										<option value="Other">@NetworkStrings.LogInteraction_Other</option>
									</select>
								</div>
								<div class="col-md-8">
									<input class="form-control" placeholder="@NetworkStrings.LogInteraction_ReferredBy" @bind="Model.ReferredByName" disabled="@(!Model.IsWarmIntro)" />
								</div>
							</div>
						</div>

						<!-- Contact selection -->
						<div class="mb-3">
							<label class="form-label">@Strings.Contact</label>
							@if (HasSelectedCompany && (CompanyContacts.Count > 0 || PersonalContacts.Count > 0))
							{
								<select class="form-select mb-2" @onchange="OnContactChanged">
									<option value="">@NetworkStrings.LogInteraction_NewContact</option>
									@if (CompanyContacts.Count > 0)
									{
										<optgroup label="@NetworkStrings.LogInteraction_CompanyContacts">
											@foreach (var ct in CompanyContacts)
											{
												<option value="@ct.Id">@ct.PersonName (@ct.Title)</option>
											}
										</optgroup>
									}
									@if (PersonalContacts.Count > 0)
									{
										<optgroup label="@Strings.PersonalContacts">
											@foreach (var ct in PersonalContacts)
											{
												<option value="@ct.Id">@ct.PersonName @(ct.Title is not null ? $"({ct.Title})" : "") @NetworkStrings.LogInteraction_Personal</option>
											}
										</optgroup>
									}
								</select>
							}
							<div class="row g-2">
								<div class="col-md-4">
									<input class="form-control" placeholder="@NetworkStrings.LogInteraction_PersonName" @bind="Model.ContactPersonName" disabled="@SelectedContactId.HasValue" />
								</div>
								<div class="col-md-4">
									<input class="form-control" placeholder="@Strings.Email" @bind="Model.ContactEmail" disabled="@SelectedContactId.HasValue" />
								</div>
								<div class="col-md-4">
									<input class="form-control" placeholder="@Strings.Phone" @bind="Model.ContactPhone" disabled="@SelectedContactId.HasValue" />
								</div>
								<div class="col-md-6">
									<input class="form-control" placeholder="@NetworkStrings.LinkedInUrl" @bind="Model.ContactLinkedInUrl" disabled="@SelectedContactId.HasValue" />
								</div>
								<div class="col-md-6">
									<input class="form-control" placeholder="@NetworkStrings.LogInteraction_TitleRole" @bind="Model.ContactTitle" disabled="@SelectedContactId.HasValue" />
								</div>
							</div>
						</div>

						<div class="mb-3">
							<label class="form-label">@Strings.Summary</label>
							<textarea class="form-control" rows="3" @bind="Model.Summary"></textarea>
						</div>

						<div class="row g-3 mb-3">
							<div class="col-md-8">
								<label class="form-label">@NetworkStrings.LogInteraction_NextAction</label>
								<input class="form-control" @bind="Model.NextAction" placeholder="@NetworkStrings.LogInteraction_ActionPlaceholder" />
							</div>
							<div class="col-md-4">
								<label class="form-label">@NetworkStrings.LogInteraction_DueDate</label>
								<input class="form-control" type="date" @bind="Model.NextActionDue" />
							</div>
						</div>

						<div class="d-flex gap-2">
							<button type="submit" class="btn btn-primary">@NetworkStrings.LogInteraction_SaveInteraction</button>
							<button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">@NetworkStrings.LogInteraction_Reset</button>
						</div>
					</EditForm>
				</div>
			</div>
		</div>

		<!-- Categories and Company history -->
		<div class="col-12 col-xl-5">
			<div class="card shadow-sm mb-3">
				<div class="card-header">
					<strong>@NetworkStrings.LogInteraction_CompanyCategories</strong>
					<div class="text-muted small">@NetworkStrings.LogInteraction_CategorySubtitle</div>
				</div>
				<div class="card-body">
					@if (_categories.Count == 0)
					{
						<div class="text-muted">@NetworkStrings.LogInteraction_NoCategories</div>
					}
					else
					{
						@foreach (var cat in _categories.OrderBy(c => c.Name))
						{
							<div class="form-check mb-2">
								<input class="form-check-input"
									   type="checkbox"
									   checked="@SelectedCompanyCategoryIds.Contains(cat.Id)"
									   @onchange="e => ToggleCompanyCategory(cat.Id, (bool)e.Value!)" />
								<label class="form-check-label">@cat.Name</label>
							</div>
						}

						@if (HasSelectedCompany)
						{
							<div class="mt-2">
								<button type="button" class="btn btn-sm btn-outline-primary"
										@onclick="SaveCompanyCategories">
									@NetworkStrings.LogInteraction_UpdateCategories
								</button>
							</div>
						}
					}
				</div>
			</div>

			<div class="card shadow-sm">
				<div class="card-header d-flex justify-content-between align-items-center">
					<strong>@NetworkStrings.LogInteraction_CompanyHistory</strong>
					<span class="badge text-bg-light border">@NetworkStrings.LogInteraction_Preview</span>
				</div>
				<div class="card-body">
					@if (!HasSelectedCompany)
					{
						<div class="text-muted">@NetworkStrings.LogInteraction_CompanyHistoryEmpty</div>
					}
					else
					{
						var c = _enrolledCompanies.FirstOrDefault(x => x.CompanyId == SelectedCompanyId!.Value);
						@if (c is not null)
						{
							<div class="mb-2">
								<div class="fw-semibold">@c.Name</div>
								<div class="text-muted small">@c.Region • @c.Website • @NetworkCompanyCard.StageLabel(c.Stage)</div>
							</div>

							<div class="mb-2">
								@foreach (var cat in c.Categories)
								{
									<span class="badge text-bg-light border me-1 mb-1">@cat.Name</span>
								}
							</div>

							<hr />

							@if (_companyHistory.Count == 0)
							{
								<div class="text-muted">@NetworkStrings.LogInteraction_NoPriorInteractions</div>
							}
							else
							{
								<ul class="list-group list-group-flush">
									@foreach (var h in _companyHistory.Take(8))
									{
										<li class="list-group-item px-0">
											<div class="d-flex justify-content-between">
												<div class="fw-semibold">@h.Date.ToString("yyyy-MM-dd")</div>
												<span class="badge text-bg-light border">@ChannelLabel(h.Channel)</span>
											</div>
											@if (!string.IsNullOrWhiteSpace(h.ContactName))
											{
												<div class="small"><Icon Kind="IconKind.PersonLinesFill" Size="12" CssClass="me-1" />@h.ContactName</div>
											}
											<div class="text-muted small">@h.Summary</div>
											<div class="mt-1">
												<span class="badge @(h.Direction == InteractionDirection.Inbound ? "text-bg-primary" : "text-bg-secondary")">@h.Direction</span>
												@if (h.IsWarmIntro)
												{
													<span class="badge text-bg-success">Warm</span>
												}
											</div>
										</li>
									}
								</ul>
							}
						}
					}
				</div>
			</div>
		</div>
	</div>
</div>
