@page "/network/activity"
@using Kulku.Application.Network.Models
@using Kulku.Domain.Network
@using Kulku.Web.Admin.Components.Network.Components

@attribute [Authorize]

<PageTitle>@NetworkStrings.ActivityLog_PageTitle</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">@NetworkStrings.ActivityLog_Heading</h1>
			<div class="text-muted">@NetworkStrings.ActivityLog_Subtitle</div>
		</div>
		<div class="d-flex flex-wrap gap-2">
			<NavLink class="btn btn-sm btn-outline-secondary" href="network">
				<span style="display:inline-block;transform:rotate(180deg)"><Icon Kind="IconKind.ChevronRight" Size="14" /></span> @NetworkStrings.ActivityLog_Dashboard
			</NavLink>
			<NavLink class="btn btn-sm btn-primary" href="network/loginteraction">
				<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />@NetworkStrings.Overview_LogInteraction
			</NavLink>
		</div>
	</div>

	@* ── Filters ── *@
	<div class="card shadow-sm mb-3">
		<div class="card-body py-2">
			<div class="row g-2 align-items-end">
				<div class="col-md-3">
					<label class="form-label small text-muted mb-1">@NetworkStrings.ActivityLog_Search</label>
					<input type="text" class="form-control form-control-sm" placeholder="@NetworkStrings.ActivityLog_SearchPlaceholder"
						   @bind="_searchText" @bind:event="oninput" />
				</div>
				<div class="col-md-3">
					<label class="form-label small text-muted mb-1">@Strings.Company</label>
					<select class="form-select form-select-sm" @bind="_filterCompanyId">
						<option value="">@NetworkStrings.ActivityLog_AllCompanies</option>
						@foreach (var c in _companies.OrderBy(c => c.Name))
						{
							<option value="@c.CompanyId">@c.Name</option>
						}
					</select>
				</div>
				<div class="col-md-2">
					<label class="form-label small text-muted mb-1">@Strings.Channel</label>
					<select class="form-select form-select-sm" @bind="_filterChannel">
						<option value="">@NetworkStrings.ActivityLog_AllChannels</option>
						@foreach (var ch in Enum.GetValues<InteractionChannel>())
						{
							<option value="@ch">@ChannelLabel(ch)</option>
						}
					</select>
				</div>
				<div class="col-md-2">
					<label class="form-label small text-muted mb-1">@Strings.Direction</label>
					<select class="form-select form-select-sm" @bind="_filterDirection">
						<option value="">@Strings.All</option>
						<option value="@InteractionDirection.Inbound">@NetworkStrings.ActivityLog_Inbound</option>
						<option value="@InteractionDirection.Outbound">@NetworkStrings.ActivityLog_Outbound</option>
					</select>
				</div>
				<div class="col-md-2 d-flex align-items-end">
					<button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearFilters">
						@NetworkStrings.ActivityLog_ClearFilters
					</button>
				</div>
			</div>
		</div>
	</div>

	@* ── Interaction list ── *@
	@{
		var filtered = FilteredInteractions;
		var visible = filtered.Take(_visibleCount).ToList();
		var hasMore = filtered.Count > _visibleCount;
	}

	@if (filtered.Count == 0)
	{
		<div class="text-muted text-center py-5">
			@if (_allInteractions.Count == 0)
			{
				<div class="mb-2">@Strings.NoInteractionsRecorded</div>
				<NavLink href="network/loginteraction" class="btn btn-sm btn-primary">@NetworkStrings.ActivityLog_LogFirst</NavLink>
			}
			else
			{
				<div>@NetworkStrings.ActivityLog_NoMatch</div>
			}
		</div>
	}
	else
	{
		<div class="mb-2 text-muted small">
			@string.Format(NetworkStrings.ActivityLog_ShowingCount, visible.Count, filtered.Count)
		</div>

		@foreach (var interaction in visible)
		{
			<InteractionCard Interaction="@interaction"
							 CompanyLink="@($"/network/companies/{interaction.CompanyId}")" />
		}

		@if (hasMore)
		{
			<div class="text-center py-3">
				<button class="btn btn-sm btn-outline-primary" @onclick="ShowMore">
					@string.Format(NetworkStrings.ActivityLog_ShowMore, filtered.Count - _visibleCount)
				</button>
			</div>
		}
	}
</div>
