@page "/network/companies"
@using Kulku.Application.Network.Models
@using Kulku.Domain.Network
@using Kulku.Web.Admin.Components.Network.Components

@attribute [Authorize]

<PageTitle>@NetworkStrings.Companies_PageTitle</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">@NetworkStrings.Companies_Heading</h1>
			<div class="text-muted">@NetworkStrings.Companies_Subtitle</div>
		</div>

		<div class="d-flex flex-wrap gap-2">
			<button class="btn btn-sm btn-primary" @onclick="HandleEnrollCompany">
				<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />@NetworkStrings.Companies_Enroll
			</button>
			<div class="btn-group btn-group-sm" role="group">
				<button class="btn @(_viewMode == ViewMode.List ? "btn-primary" : "btn-outline-primary")"
						@onclick="() => _viewMode = ViewMode.List">
					<Icon Kind="IconKind.ListNested" Size="14" CssClass="me-1" />@NetworkStrings.Companies_ListView
				</button>
				<button class="btn @(_viewMode == ViewMode.Pipeline ? "btn-primary" : "btn-outline-primary")"
						@onclick="() => _viewMode = ViewMode.Pipeline">
					<Icon Kind="IconKind.Kanban" Size="14" CssClass="me-1" />@NetworkStrings.Pipeline
				</button>
			</div>
		</div>
	</div>

	@* ── Filters (list view only) ── *@
	@if (_viewMode == ViewMode.List)
	{
		<div class="row g-2 mb-3">
			<div class="col-md-3">
				<input type="text" class="form-control form-control-sm" placeholder="@Strings.Search"
					   @bind="_searchText" @bind:event="oninput" />
			</div>
			<div class="col-md-2">
				<select class="form-select form-select-sm" @bind="_filterStage">
					<option value="">@Strings.AllStages</option>
					@foreach (var s in Enum.GetValues<CompanyStage>())
					{
						<option value="@s">@NetworkCompanyCard.StageLabel(s)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<select class="form-select form-select-sm" @bind="_filterCategoryId">
					<option value="@Guid.Empty">@NetworkStrings.Companies_AllCategories</option>
					@foreach (var c in _categories.OrderBy(c => c.Name))
					{
						<option value="@c.Id">@c.Name</option>
					}
				</select>
			</div>
		</div>
	}

	@* ── Content ── *@
	@if (_viewMode == ViewMode.List)
	{
		var filtered = FilteredCompanies;
		if (filtered.Count == 0)
		{
			<div class="text-muted text-center py-4">
				@(_companies.Count == 0
				? NetworkStrings.Companies_NoCompanies
				: NetworkStrings.Companies_NoMatch)
			</div>
		}
		else
		{
			@foreach (var company in filtered)
			{
				var lastDate = _interactions
				.Where(i => i.CompanyId == company.CompanyId)
				.Select(i => (DateTime?)i.Date)
				.FirstOrDefault();

				<NetworkCompanyCard Company="@company"
									LastInteractionDate="@lastDate"
									OnEdit="HandleEditCompany"
									OnDelete="HandleDeleteCompany" />
			}
		}
	}
	else
	{
		<div class="row g-3">
			@foreach (var stage in Enum.GetValues<CompanyStage>())
			{
				<div class="col-12 col-md-6 col-xl-2">
					<PipelineColumn Stage="@stage" Companies="@GetPipelineItems(stage)" />
				</div>
			}
		</div>
	}

	@* ── Personal contacts section (collapsible) ── *@
	<div class="mt-4">
		<div class="d-flex align-items-center gap-2 mb-2 cursor-pointer"
			 @onclick="() => _personalContactsExpanded = !_personalContactsExpanded">
			<Icon Kind="@(_personalContactsExpanded ? IconKind.ChevronDown : IconKind.ChevronRight)" Size="16" />
			<h5 class="mb-0">@Strings.PersonalContacts</h5>
			<span class="badge bg-secondary">@_personalContacts.Count</span>
		</div>

		@if (_personalContactsExpanded)
		{
			<div class="mb-2">
				<button class="btn btn-outline-primary btn-sm" @onclick="HandleCreatePersonalContact">
					<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />@NetworkStrings.Companies_NewPersonalContact
				</button>
			</div>

			@if (_personalContacts.Count == 0)
			{
				<p class="text-muted">@NetworkStrings.Companies_NoPersonalContacts</p>
			}
			else
			{
				@foreach (var contact in _personalContacts.OrderBy(c => c.PersonName))
				{
					<div class="card mb-2">
						<div class="card-body py-2 px-3">
							<div class="d-flex justify-content-between align-items-start">
								<div>
									<div class="fw-semibold small">@(contact.PersonName ?? NetworkStrings.Detail_Unnamed)</div>
									@if (!string.IsNullOrWhiteSpace(contact.Title))
									{
										<small class="text-muted">@contact.Title</small>
									}
									<div class="d-flex flex-wrap gap-2 mt-1">
										@if (!string.IsNullOrWhiteSpace(contact.Email))
										{
											<small class="text-muted">📧 @contact.Email</small>
										}
										@if (!string.IsNullOrWhiteSpace(contact.Phone))
										{
											<small class="text-muted">📱 @contact.Phone</small>
										}
									</div>
									@if (!string.IsNullOrWhiteSpace(contact.LinkedInUrl))
									{
										<div class="mt-1">
											<a href="@contact.LinkedInUrl" target="_blank"
											   class="text-decoration-none small">@NetworkStrings.NetworkContact_LinkedIn</a>
										</div>
									}
								</div>

								<div class="d-flex gap-1">
									<div class="dropdown">
										<button class="btn btn-sm btn-outline-success dropdown-toggle" title="@NetworkStrings.Companies_LinkToCompany"
												data-bs-toggle="dropdown" data-bs-auto-close="true">
											<Icon Kind="IconKind.Building" Size="12" />
										</button>
										<ul class="dropdown-menu dropdown-menu-end">
											<li><h6 class="dropdown-header">@NetworkStrings.Companies_LinkToCompany</h6></li>
											@foreach (var c in _companies.OrderBy(c => c.Name))
											{
												<li>
													<button class="dropdown-item small"
															@onclick="() => HandleLinkPersonalContact(contact.Id, c.CompanyId)">
														@c.Name
													</button>
												</li>
											}
										</ul>
									</div>
									<button class="btn btn-sm btn-outline-danger" title="@Strings.Delete"
											@onclick="() => HandleDeletePersonalContact(contact.Id)">
										<Icon Kind="IconKind.Trash" Size="12" />
									</button>
								</div>
							</div>
						</div>
					</div>
				}
			}
		}
	</div>

	@* ── Categories section (collapsible) ── *@
	<div class="mt-4">
		<div class="d-flex align-items-center gap-2 mb-2 cursor-pointer"
			 @onclick="() => _categoriesExpanded = !_categoriesExpanded">
			<Icon Kind="@(_categoriesExpanded ? IconKind.ChevronDown : IconKind.ChevronRight)" Size="16" />
			<h5 class="mb-0">@Strings.Categories</h5>
			<span class="badge bg-secondary">@_categories.Count</span>
		</div>

		@if (_categoriesExpanded)
		{
			<div class="mb-2">
				<button class="btn btn-outline-primary btn-sm" @onclick="HandleCreateCategory">
					<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />@NetworkStrings.Companies_NewCategory
				</button>
			</div>

			@if (_categories.Count == 0)
			{
				<p class="text-muted">@NetworkStrings.Companies_NoCategories</p>
			}
			else
			{
				@foreach (var cat in _categories.OrderBy(c => c.Name))
				{
					<CategoryCard Category="@cat" OnEdit="HandleEditCategory" OnDelete="HandleDeleteCategory" />
				}
			}
		}
	</div>
</div>

@* ── Modals ── *@
<NetworkCompanyEditModal @ref="_companyModal"
						 IsVisible="@(_companyMode is not null)"
						 Mode="@(_companyMode ?? ModalMode.Edit)"
						 Categories="@_categories"
						 AvailableCompanies="@_availableCompanies"
						 OnSave="HandleSaveCompany"
						 OnCancel="CloseCompanyEditor" />

<NetworkCategoryEditModal @ref="_categoryModal"
						  IsVisible="@(_categoryMode is not null)"
						  Mode="@(_categoryMode ?? ModalMode.Create)"
						  OnSave="HandleSaveCategory"
						  OnCancel="CloseCategoryEditor" />

<NetworkContactEditModal @ref="_contactModal"
						 IsVisible="@(_contactMode is not null)"
						 Mode="@(_contactMode ?? ModalMode.Create)"
						 OnSave="HandleSavePersonalContact"
						 OnCancel="ClosePersonalContactEditor" />
