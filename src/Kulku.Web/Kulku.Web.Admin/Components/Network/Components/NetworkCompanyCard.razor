@using Kulku.Application.Network.Models
@using Kulku.Domain.Network

<div class="card mb-2">
	<div class="card-body py-2 px-3">
		<div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
			<div class="flex-grow-1 min-w-0">
				<div class="d-flex flex-wrap align-items-center gap-2 mb-1">
					<span class="badge @StageBadgeClass(Company.Stage)">@StageLabel(Company.Stage)</span>
					@if (!string.IsNullOrWhiteSpace(Company.Region))
					{
						<small class="text-muted">@Company.Region</small>
					}
				</div>

				<h6 class="mb-1">
					<a href="/network/companies/@Company.CompanyId" class="text-decoration-none">@Company.Name</a>
				</h6>

				@if (Company.Categories.Count > 0)
				{
					<div class="d-flex flex-wrap gap-1 mb-1">
						@foreach (var cat in Company.Categories)
						{
							<span class="badge text-bg-@(cat.ColorToken ?? "secondary") bg-opacity-50 fw-normal">@cat.Name</span>
						}
					</div>
				}

				<div class="d-flex flex-wrap align-items-center gap-3 mt-1">
					@if (Company.ContactCount > 0)
					{
						<small class="text-muted">
							<Icon Kind="IconKind.PersonLinesFill" Size="12" CssClass="me-1" />@Company.ContactCount @NetworkStrings.Companies_Contacts
						</small>
					}
					@if (Company.InteractionCount > 0)
					{
						<small class="text-muted">
							<Icon Kind="IconKind.ChatDots" Size="12" CssClass="me-1" />@Company.InteractionCount @NetworkStrings.Companies_Interactions
						</small>
					}
					@if (LastInteractionDate.HasValue)
					{
						<small class="@RecencyTextClass(LastInteractionDate.Value)">
							@NetworkStrings.Companies_Last @LastInteractionDate.Value.ToString("yyyy-MM-dd")
						</small>
					}
				</div>
			</div>

			<div class="d-flex gap-1 flex-shrink-0">
				<button class="btn btn-sm btn-outline-primary" title="@Strings.Edit"
						@onclick="() => OnEdit.InvokeAsync(Company.CompanyId)">
					<Icon Kind="IconKind.Pencil" Size="14" />
				</button>
				@if (!_confirmDelete)
				{
					<button class="btn btn-sm btn-outline-danger" title="@Strings.Delete"
							@onclick="() => _confirmDelete = true">
						<Icon Kind="IconKind.Trash" Size="14" />
					</button>
				}
				else
				{
					<button class="btn btn-sm btn-danger" title="@Strings.ConfirmDelete"
							@onclick="() => OnDelete.InvokeAsync(Company.CompanyId)">
						<Icon Kind="IconKind.Check" Size="14" />
					</button>
					<button class="btn btn-sm btn-outline-secondary" title="@Strings.Cancel"
							@onclick="() => _confirmDelete = false">
						✕
					</button>
				}
			</div>
		</div>
	</div>
</div>
