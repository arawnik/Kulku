@using Kulku.Application.Network.Models
@using Kulku.Domain.Network

<ModalDialog Visible="@IsVisible" Title="@ModalTitle"
			 Size="ModalSize.Large"
			 OnClose="OnCancel">
	<ChildContent>
		<EditForm Model="@Form" OnValidSubmit="HandleSave">
			<DataAnnotationsValidator />

			@if (Mode == ModalMode.Create)
			{
				<div class="mb-3">
					<div class="btn-group btn-group-sm w-100 mb-2" role="group">
						<button type="button"
								class="btn @(!Form.IsNewCompany ? "btn-primary" : "btn-outline-primary")"
								@onclick="() => Form.IsNewCompany = false">
							@NetworkStrings.NetworkCompany_PickExisting
						</button>
						<button type="button"
								class="btn @(Form.IsNewCompany ? "btn-primary" : "btn-outline-primary")"
								@onclick="() => Form.IsNewCompany = true">
							@NetworkStrings.NetworkCompany_CreateNew
						</button>
					</div>

					@if (Form.IsNewCompany)
					{
						<div class="mb-2">
							<label class="form-label">@Strings.CompanyName <span class="text-danger">*</span></label>
							<InputText class="form-control" @bind-Value="Form.NewCompanyName" placeholder="@Strings.CompanyName" />
							<ValidationMessage For="@(() => Form.NewCompanyName)" />
						</div>
						<div class="row g-2">
							<div class="col-md-6">
								<label class="form-label">@Strings.Website</label>
								<InputText class="form-control" @bind-Value="Form.NewCompanyWebsite" placeholder="https://..." />
							</div>
							<div class="col-md-6">
								<label class="form-label">@Strings.Region</label>
								<InputText class="form-control" @bind-Value="Form.NewCompanyRegion" placeholder="@NetworkStrings.NetworkCompany_RegionPlaceholder" />
							</div>
						</div>
					}
					else
					{
						<label class="form-label">@Strings.Company</label>
						@if (AvailableCompanies.Count == 0)
						{
							<div class="text-muted small">@NetworkStrings.NetworkCompany_AllEnrolled</div>
						}
						else
						{
							<InputSelect class="form-select" @bind-Value="Form.SelectedCompanyId">
								<option value="@Guid.Empty">@NetworkStrings.NetworkCompany_SelectCompany</option>
								@foreach (var c in AvailableCompanies.OrderBy(c => c.Name))
								{
									<option value="@c.CompanyId">@c.Name @(c.Region is not null ? $"({c.Region})" : "")</option>
								}
							</InputSelect>
							<ValidationMessage For="@(() => Form.SelectedCompanyId)" />
						}
					}
				</div>
			}

			<div class="mb-3">
				<label class="form-label">@Strings.Stage</label>
				<InputSelect class="form-select" @bind-Value="Form.Stage">
					@foreach (var s in Enum.GetValues<CompanyStage>())
					{
						<option value="@s">@NetworkCompanyCard.StageLabel(s)</option>
					}
				</InputSelect>
			</div>

			<div class="mb-3">
				<label class="form-label">@Strings.Notes</label>
				<InputTextArea class="form-control" rows="3" @bind-Value="Form.Notes" />
			</div>

			<div class="mb-3">
				<label class="form-label">@Strings.Categories</label>
				<div class="d-flex flex-wrap gap-2">
					@foreach (var cat in Categories.OrderBy(c => c.Name))
					{
						<div class="form-check">
							<input class="form-check-input" type="checkbox"
								   checked="@Form.CategoryIds.Contains(cat.Id)"
								   @onchange="e => ToggleCategory(cat.Id, (bool)e.Value!)" />
							<label class="form-check-label">@cat.Name</label>
						</div>
					}
				</div>
			</div>

			<div class="d-flex gap-2">
				<button type="submit" class="btn btn-primary"
						disabled="@IsSubmitDisabled">
					@SubmitLabel
				</button>
				<button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">@Strings.Cancel</button>
			</div>
		</EditForm>
	</ChildContent>
</ModalDialog>
