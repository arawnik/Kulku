@using Kulku.Web.Admin.Components.Network

<ModalDialog Visible="@IsVisible" Title="@(Mode == ModalMode.Create ? NetworkStrings.NetworkCategory_NewTitle : NetworkStrings.NetworkCategory_EditTitle)"
			 Size="ModalSize.Small"
			 OnClose="OnCancel">
	<ChildContent>
		<EditForm Model="@Form" OnValidSubmit="HandleSave">
			<DataAnnotationsValidator />

			<div class="mb-3">
				<label class="form-label">@Strings.Name</label>
				<InputText class="form-control" @bind-Value="Form.Name" />
				<ValidationMessage For="() => Form.Name" />
			</div>

			<div class="mb-3">
				<label class="form-label">@NetworkStrings.NetworkCategory_ColorToken</label>
				<InputSelect class="form-select" @bind-Value="Form.ColorToken">
					<option value="">@NetworkStrings.NetworkCategory_NoneOption</option>
					<option value="primary">primary</option>
					<option value="secondary">secondary</option>
					<option value="success">success</option>
					<option value="danger">danger</option>
					<option value="warning">warning</option>
					<option value="info">info</option>
				</InputSelect>
				<div class="form-text">@NetworkStrings.NetworkCategory_ColorHelp</div>
			</div>

			<div class="d-flex gap-2">
				<button type="submit" class="btn btn-primary">
					@(Mode == ModalMode.Create ? Strings.Create : Strings.SaveChanges)
				</button>
				<button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">@Strings.Cancel</button>
			</div>
		</EditForm>
	</ChildContent>
</ModalDialog>
