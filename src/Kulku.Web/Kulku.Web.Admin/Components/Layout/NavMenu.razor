@using Kulku.Web.Admin.Options

@inject NavigationManager NavigationManager
@inject IOptions<ManagementOptions> ManagementOptions

<nav class="kulku-sidebar @(IsCollapsed ? "kulku-sidebar--collapsed" : string.Empty)">

	@* ── Header: brand + toggle ── *@
	<div class="kulku-sidebar__header">
		@if (!IsCollapsed)
		{
			<NavLink class="d-flex align-items-center gap-2 text-white text-decoration-none" href="">
				<span class="fs-5 fw-semibold">Kulku Admin</span>
			</NavLink>
		}

		<button type="button"
				class="btn btn-sm btn-outline-light kulku-sidebar-toggle"
				title="Toggle sidebar"
				@onclick="ToggleCollapsed">
			<Icon Kind="@(IsCollapsed? IconKind.ArrowBarRight: IconKind.ArrowBarLeft)" Size="20" />
			<span class="visually-hidden">Toggle sidebar</span>
		</button>
	</div>

	<hr class="my-2" />

	@* ── Scrollable nav area ── *@
	<ul class="nav nav-pills flex-column kulku-sidebar__nav">
		<li class="nav-item">
			<NavLink class="nav-link text-white kulku-navlink" href="" Match="NavLinkMatch.All"
					 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Home" : null)">
				<Icon Kind="IconKind.House" Size="20" />
				<span class="kulku-link-text">Home</span>
			</NavLink>
		</li>

		<AuthorizeView>
			<li class="nav-item">
				<NavLink class="nav-link text-white kulku-navlink" href="inbox" Match="NavLinkMatch.All"
						 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Inbox" : null)">
					<Icon Kind="IconKind.Envelope" Size="20" />
					<span class="kulku-link-text">
						Inbox
						@if (_newCount > 0)
						{
							<span class="badge text-bg-danger ms-1">@_newCount</span>
						}
					</span>
				</NavLink>
			</li>

			<li class="nav-item">
				<NavLink class="nav-link text-white kulku-navlink" href="network"
						 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Network" : null)">
					<Icon Kind="IconKind.Lightbulb" Size="20" />
					<span class="kulku-link-text">Network</span>
				</NavLink>

				@if (!IsCollapsed)
				{
					<ul class="nav flex-column kulku-subnav">
						<li><NavLink class="nav-link kulku-sublink" href="network" Match="NavLinkMatch.All"><Icon Kind="IconKind.Speedometer" Size="14" /> Dashboard</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="network/companies"><Icon Kind="IconKind.Building" Size="14" /> Companies</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="network/loginteraction"><Icon Kind="IconKind.ChatDots" Size="14" /> Log Interaction</NavLink></li>
					</ul>
				}
			</li>

			<li class="nav-item">
				<NavLink class="nav-link text-white kulku-navlink" href="cv"
						 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Cv" : null)">
					<Icon Kind="IconKind.FileEarmarkPerson" Size="20" />
					<span class="kulku-link-text">Cv</span>
				</NavLink>

				@if (!IsCollapsed)
				{
					<ul class="nav flex-column kulku-subnav">
						<li><NavLink class="nav-link kulku-sublink" href="cv" Match="NavLinkMatch.All"><Icon Kind="IconKind.Speedometer" Size="14" /> Overview</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="cv/introduction"><Icon Kind="IconKind.FileText" Size="14" /> Introduction</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="cv/education"><Icon Kind="IconKind.Mortarboard" Size="14" /> Education</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="cv/experience"><Icon Kind="IconKind.Briefcase" Size="14" /> Experience</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="cv/projects"><Icon Kind="IconKind.Folder" Size="14" /> Projects</NavLink></li>
						<li><NavLink class="nav-link kulku-sublink" href="cv/keywords"><Icon Kind="IconKind.Tags" Size="14" /> Keywords</NavLink></li>
					</ul>
				}
			</li>

			<li class="nav-item">
				<NavLink class="nav-link text-white kulku-navlink" href="ideas"
						 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Ideas" : null)">
					<Icon Kind="IconKind.Journal" Size="20" />
					<span class="kulku-link-text">Ideas</span>
				</NavLink>
			</li>
		</AuthorizeView>
	</ul>

	@* ── Footer: user menu ── *@
	<div class="kulku-sidebar__footer">
		<hr class="my-2" />

		<AuthorizeView>
			<Authorized>
				<div class="@(IsCollapsed ? "dropend" : "dropup")">
					<a class="d-flex align-items-center gap-2 text-white text-decoration-none dropdown-toggle kulku-user-toggle"
						   href="#"
						   data-bs-toggle="dropdown"
						   aria-expanded="false">
						<Icon Kind="IconKind.PersonFill" Size="20" />
						<strong class="kulku-link-text">@context.User.Identity?.Name</strong>
					</a>

					<ul class="dropdown-menu dropdown-menu-dark text-small shadow">
						<li>
							<NavLink class="dropdown-item" href="Account/Manage">Profile</NavLink>
						</li>
						<li><hr class="dropdown-divider" /></li>
						<li>
							<form class="px-3 py-2" action="Account/Logout" method="post">
								<AntiforgeryToken />
								<input type="hidden" name="ReturnUrl" value="@currentUrl" />
								<button type="submit" class="btn btn-sm btn-danger w-100">Logout</button>
							</form>
						</li>
					</ul>
				</div>
			</Authorized>

			<NotAuthorized>
				<ul class="nav nav-pills flex-column">
					<li class="nav-item">
						<NavLink class="nav-link text-white kulku-navlink" href="Account/Login"
								 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Login" : null)">
							<Icon Kind="IconKind.PersonBadge" Size="20" />
							<span class="kulku-link-text">Login</span>
						</NavLink>
					</li>
					@if (ManagementOptions.Value.RegistrationEnabled)
					{
						<li class="nav-item">
							<NavLink class="nav-link text-white kulku-navlink" href="Account/Register"
									 data-bs-toggle="@(IsCollapsed ? "tooltip" : null)" data-bs-placement="right" title="@(IsCollapsed ? "Register" : null)">
								<Icon Kind="IconKind.Person" Size="20" />
								<span class="kulku-link-text">Register</span>
							</NavLink>
						</li>
					}
				</ul>
			</NotAuthorized>
		</AuthorizeView>
	</div>
</nav>
