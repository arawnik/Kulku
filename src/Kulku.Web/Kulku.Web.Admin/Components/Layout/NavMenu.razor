@implements IDisposable

@inject NavigationManager NavigationManager

<div class="d-flex flex-column flex-shrink-0 p-3 text-bg-dark kulku-sidebar @(IsCollapsed ? "kulku-sidebar--collapsed" : string.Empty)">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <NavLink class="d-flex align-items-center gap-2 text-white text-decoration-none" href="" Match="NavLinkMatch.All">
      <span class="fs-5 fw-semibold kulku-brand-text">Kulku</span>
    </NavLink>

    <button type="button" class="btn btn-sm btn-outline-light kulku-sidebar-toggle" title="Toggle sidebar" @onclick="ToggleCollapsed">
      <span class="bi bi-arrow-bar-left-nav-menu kulku-toggle-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Toggle sidebar</span>
    </button>
  </div>

  <hr class="my-2" />

  <ul class="nav nav-pills flex-column mb-auto">
    <li class="nav-item">
      <NavLink class="nav-link text-white kulku-navlink" href="" Match="NavLinkMatch.All">
        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
        <span class="kulku-link-text">Home</span>
      </NavLink>
    </li>

    <li class="nav-item">
      <NavLink class="nav-link text-white kulku-navlink" href="developer">
        <span class="bi bi-lightbulb-nav-menu" aria-hidden="true"></span>
        <span class="kulku-link-text">Developer</span>
      </NavLink>
    </li>

    <li class="nav-item">
      <NavLink class="nav-link text-white kulku-navlink" href="counter">
        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
        <span class="kulku-link-text">Counter</span>
      </NavLink>
    </li>

    <li class="nav-item">
      <NavLink class="nav-link text-white kulku-navlink" href="weather">
        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>
        <span class="kulku-link-text">Weather</span>
      </NavLink>
    </li>

    <li class="nav-item">
      <NavLink class="nav-link text-white kulku-navlink" href="auth">
        <span class="bi bi-lock-nav-menu" aria-hidden="true"></span>
        <span class="kulku-link-text">Auth Required</span>
      </NavLink>
    </li>
  </ul>

  <hr class="my-2" />

  <AuthorizeView>
    <Authorized>
      <div class="dropdown">
        <a class="d-flex align-items-center gap-2 text-white text-decoration-none dropdown-toggle"
           href="#"
           data-bs-toggle="dropdown"
           aria-expanded="false">
          <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
          <strong class="kulku-link-text">@context.User.Identity?.Name</strong>
        </a>

        <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
          <li>
            <NavLink class="dropdown-item" href="Account/Manage">Profile</NavLink>
          </li>
          <li><hr class="dropdown-divider" /></li>
          <li>
            <form class="px-3 py-2" action="Account/Logout" method="post">
              <AntiforgeryToken />
              <input type="hidden" name="ReturnUrl" value="@currentUrl" />
              <button type="submit" class="btn btn-sm btn-danger w-100">Logout</button>
            </form>
          </li>
        </ul>
      </div>
    </Authorized>

    <NotAuthorized>
      <ul class="nav nav-pills flex-column">
        <li class="nav-item">
          <NavLink class="nav-link text-white kulku-navlink" href="Account/Login">
            <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span>
            <span class="kulku-link-text">Login</span>
          </NavLink>
        </li>
        <li class="nav-item">
          <NavLink class="nav-link text-white kulku-navlink" href="Account/Register">
            <span class="bi bi-person-nav-menu" aria-hidden="true"></span>
            <span class="kulku-link-text">Register</span>
          </NavLink>
        </li>
      </ul>
    </NotAuthorized>
  </AuthorizeView>
</div>

@code {
  private string? currentUrl;

  // Prototype-only: keep in-memory. If you want, we can persist per-user later.
  private bool IsCollapsed { get; set; }

  protected override void OnInitialized()
  {
    currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
    NavigationManager.LocationChanged += OnLocationChanged;
  }

  private void ToggleCollapsed() => IsCollapsed = !IsCollapsed;

  private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
  {
    currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
    StateHasChanged();
  }

  public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;
}
