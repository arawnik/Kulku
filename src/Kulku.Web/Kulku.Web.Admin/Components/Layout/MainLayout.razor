@inherits LayoutComponentBase

@* ── Mobile top bar (visible < md) ── *@
<header class="kulku-mobile-topbar d-md-none">
	<button class="btn btn-sm btn-outline-light"
			type="button"
			@onclick="ToggleMobileMenu"
			aria-label="@LayoutStrings.OpenMenu">
		<Icon Kind="IconKind.HamburgerMenu" Size="20" />
	</button>
	<span class="fs-5 fw-semibold text-white">@LayoutStrings.AppTitle</span>
</header>

@* ── Mobile drawer (visible < md) ── *@
@if (_showMobileMenu)
{
	<div class="kulku-backdrop d-md-none" @onclick="CloseMobileMenu"></div>
}
<div class="kulku-drawer d-md-none @(_showMobileMenu ? "kulku-drawer--open" : "")">
	<div class="kulku-drawer__header">
		<span class="fs-5 fw-semibold text-white">@LayoutStrings.AppTitle</span>
		<button type="button" class="btn-close btn-close-white" @onclick="CloseMobileMenu" aria-label="@Strings.Close"></button>
	</div>
	<div class="kulku-drawer__body">
		<NavMenu IsMobile="true" OnCloseMobile="CloseMobileMenu" />
	</div>
</div>

<div class="page">
	@* ── Desktop sidebar (visible >= md) ── *@
	<aside class="d-none d-md-block">
		<NavMenu />
	</aside>

	<main>
		<article class="content px-4">
			@Body
		</article>
	</main>
</div>

<div id="blazor-error-ui" data-nosnippet>
	@LayoutStrings.Error_Unhandled
	<a href="." class="reload">@Strings.Reload</a>
	<span class="dismiss">🗙</span>
</div>

@code {
	private bool _showMobileMenu;

	private void ToggleMobileMenu() => _showMobileMenu = !_showMobileMenu;
	private void CloseMobileMenu() => _showMobileMenu = false;
}
