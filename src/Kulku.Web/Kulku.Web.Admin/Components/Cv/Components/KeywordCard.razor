@using Kulku.Application.Projects.Models

<div class="card shadow-sm mb-2 border-opacity-50 @(Keyword.Display ? "border-success" : "border-secondary")">
	<div class="card-body py-2">
		<div class="d-flex justify-content-between align-items-start">
			@* Left: visibility + translations *@
			<div class="d-flex gap-2 align-items-start flex-grow-1">
				<div class="pt-1">
					@if (Keyword.Display)
					{
						<span class="text-success" title="@CvStrings.Keywords_VisibleOnCv">
							<Icon Kind="IconKind.Eye" Size="16" />
						</span>
					}
					else
					{
						<span class="text-muted" title="@CvStrings.Keywords_HiddenFromCv">
							<Icon Kind="IconKind.EyeSlash" Size="16" />
						</span>
					}
				</div>

				<div class="flex-grow-1">
					@* Translations *@
					@{
						var kwTranslations = Keyword.Translations.OrderBy(t => t.Language.ToString()).ToList();
						var kwAllMatch = kwTranslations.Count > 1 && kwTranslations.All(t => t.Name == kwTranslations[0].Name);
					}
					<div class="mb-1">
						@if (kwAllMatch)
						{
							<span class="fw-semibold" title="Same in all languages: @string.Join(", ", kwTranslations.Select(t => LanguageDisplayHelper.DisplayName(t.Language)))">
								@kwTranslations[0].Name
							</span>
						}
						else
						{
							@foreach (var trans in kwTranslations)
							{
								<span class="me-3">
									<span class="text-muted small me-1">@LanguageDisplayHelper.DisplayName(trans.Language)</span>
									<span class="fw-semibold">@trans.Name</span>
								</span>
							}
						}
					</div>

					@* Metadata row *@
					<div class="d-flex flex-wrap gap-2 align-items-center">
						<span class="badge bg-info bg-opacity-25 text-body-emphasis">
							@Keyword.ProficiencyName · @(Keyword.ProficiencyScale)%
						</span>
						<span class="text-muted small">@Strings.Order: @Keyword.Order</span>
					</div>
				</div>
			</div>

			@* Right: action buttons *@
			<div class="d-flex gap-1 ms-3">
				<button type="button" class="btn btn-sm btn-outline-primary"
						@onclick="HandleEditClick">
					<Icon Kind="IconKind.Pencil" Size="14" />
				</button>
				<button type="button" class="btn btn-sm btn-outline-danger"
						@onclick="() => _confirmingDelete = true">
					<Icon Kind="IconKind.Trash" Size="14" />
				</button>
			</div>
		</div>
	</div>
</div>

<ConfirmDialog Visible="_confirmingDelete"
			   Title="@CvStrings.Keywords_DeleteTitle"
			   Message="@CvStrings.Keywords_DeleteMessage"
			   ButtonText="@Strings.Delete"
			   ButtonStyle="danger"
			   ButtonIcon="IconKind.Trash"
			   OnConfirm="HandleConfirmDelete"
			   OnCancel="() => _confirmingDelete = false" />

