@using Kulku.Application.Projects.Models

<div class="card shadow-sm mb-2">
	<div class="card-body py-2">
		<div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
			@* Left: scale badge + translations *@
			<div class="d-flex gap-3 align-items-start flex-grow-1">
				<span class="badge bg-primary fs-6 mt-1" style="min-width:3rem">@Proficiency.Scale%</span>

				<div class="flex-grow-1">
					@* Translations *@
					@{
						var profTranslations = Proficiency.Translations.OrderBy(t => t.Language.ToString()).ToList();
						var profAllMatch = profTranslations.Count > 1 && profTranslations.All(t => t.Name == profTranslations[0].Name);
					}
					<div class="mb-1">
						@if (profAllMatch)
						{
							<span class="fw-semibold" title="Same in all languages: @string.Join(", ", profTranslations.Select(t => LanguageDisplayHelper.DisplayName(t.Language)))">
								@profTranslations[0].Name
							</span>
						}
						else
						{
							@foreach (var trans in profTranslations)
							{
								<span class="me-3">
									<span class="text-muted small me-1">@LanguageDisplayHelper.DisplayName(trans.Language)</span>
									<span class="fw-semibold">@trans.Name</span>
								</span>
							}
						}
					</div>

					@* Metadata row *@
					<div class="d-flex flex-wrap gap-2 align-items-center">
						<span class="text-muted small">@Strings.Order: @Proficiency.Order</span>
						<span class="badge bg-secondary bg-opacity-25 text-body-emphasis">
							@Proficiency.KeywordCount @CvStrings.Proficiency_KeywordCount
						</span>
					</div>
				</div>
			</div>

			@* Right: action buttons *@
			<div class="d-flex gap-1">
				<button type="button" class="btn btn-sm btn-outline-primary"
						@onclick="() => OnEdit.InvokeAsync(Proficiency.ProficiencyId)">
					<Icon Kind="IconKind.Pencil" Size="14" />
				</button>
				<button type="button" class="btn btn-sm btn-outline-danger"
						@onclick="() => _confirmingDelete = true"
						disabled="@(Proficiency.KeywordCount > 0)">
					<Icon Kind="IconKind.Trash" Size="14" />
				</button>
			</div>
		</div>
	</div>
</div>

<ConfirmDialog Visible="_confirmingDelete"
			   Title="@CvStrings.Proficiency_DeleteTitle"
			   Message="@CvStrings.Proficiency_DeleteMessage"
			   ButtonText="@Strings.Delete"
			   ButtonStyle="danger"
			   ButtonIcon="IconKind.Trash"
			   OnConfirm="HandleConfirmDelete"
			   OnCancel="() => _confirmingDelete = false" />
