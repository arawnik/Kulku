@using Kulku.Application.Cover.Introduction.Models
@using Kulku.Application.Abstractions.Assets

@inject IAssetUrlBuilder StaticAssets

<div class="card shadow-sm @(IsActive ? "border-success" : "")">
	@if (Introduction is not null)
	{
		var translations = Introduction.Translations
			.OrderBy(t => t.Language.ToString()).ToList();

		<div class="card-header d-flex justify-content-between align-items-start gap-3">
			<div class="d-flex align-items-center gap-3">
				<img src="@StaticAssets.Introduction(Introduction.SmallAvatarUrl)" alt="Avatar"
					 class="rounded-circle flex-shrink-0"
					 style="width:48px;height:48px;object-fit:cover;"
					 onerror="this.style.display='none'" />
				<div>
					<h5 class="mb-0 fw-semibold">
						@(translations.FirstOrDefault()?.Title ?? Strings.Untitled)
					</h5>
					<div class="text-muted small">
						@(translations.FirstOrDefault()?.Tagline ?? string.Empty)
					</div>
				</div>
			</div>
			<div class="d-flex align-items-center gap-2">
				<span class="badge @StatusBadgeClass">@StatusLabel</span>
				<span class="text-muted small text-nowrap">
					@Introduction.PubDate.ToString("yyyy-MM-dd HH:mm")
				</span>
			</div>
		</div>

		<div class="card-body">
			@if (translations.Count == 0)
			{
				<div class="text-muted small">@Strings.NoTranslationsAvailable</div>
			}
			else
			{
				<div class="row g-3">
					@foreach (var trans in translations)
					{
						<div class="@(translations.Count == 1 ? "col-12" : "col-12 col-md-6")">
							<div class="d-flex align-items-center gap-2 mb-2">
								<span class="badge bg-secondary">
									@LanguageDisplayHelper.DisplayName(trans.Language)
								</span>
								<span class="fw-semibold small">@trans.Title</span>
							</div>
							<div class="text-muted small mb-1">@trans.Tagline</div>
							@if (!string.IsNullOrWhiteSpace(trans.Content))
							{
								<div class="text-muted small intro-content">
									<MarkdownView Content="@trans.Content" />
								</div>
							}
						</div>
					}
				</div>
			}
		</div>

		<div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
			<div class="d-flex align-items-center gap-2">
				<button type="button" class="btn btn-sm btn-outline-primary"
						@onclick="HandleEditClick">
					<Icon Kind="IconKind.Pencil" Size="14" CssClass="me-1" />@Strings.Edit
				</button>
				<button type="button" class="btn btn-sm btn-outline-danger"
						@onclick="() => _confirmingDelete = true">
					<Icon Kind="IconKind.Trash" Size="14" CssClass="me-1" />@Strings.Delete
				</button>
			</div>
			<small class="text-muted">
				@translations.Count @Strings.TranslationCount
			</small>
		</div>
	}
</div>

<ConfirmDialog Visible="_confirmingDelete"
			   Title="@CvStrings.Introduction_DeleteTitle"
			   Message="@CvStrings.Introduction_DeleteMessage"
			   ButtonText="@Strings.Delete"
			   ButtonStyle="danger"
			   ButtonIcon="IconKind.Trash"
			   OnConfirm="HandleConfirmDelete"
			   OnCancel="() => _confirmingDelete = false" />
