@using System.ComponentModel.DataAnnotations
@using Kulku.Application.Projects.Models
@using Kulku.Domain
@using Kulku.Domain.Projects
@using SoulNETLib.Clean.Domain

<ModalDialog Visible="@(_form != null)"
			 Title="@(Mode == ModalMode.Create ? "Create Project" : "Edit Project")"
			 Size="ModalSize.Large"
			 OnClose="OnCancel">
	<ChildContent>
		@if (ErrorMessage is not null)
		{
			<div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
		}
		@if (_form != null)
		{
			<EditForm EditContext="@_editContext">
				<DataAnnotationsValidator />
				<ServerValidation @ref="_serverValidation" />

				<div class="row g-3 mb-4">
					<div class="col-md-5">
						<label class="form-label">Project URL</label>
						<InputText @bind-Value="_form.Url" class="form-control"
								   placeholder="https://..." disabled="@IsSaving" />
						<ValidationMessage For="@(() => _form.Url)" />
					</div>
					<div class="col-md-5">
						<label class="form-label">Image filename</label>
						<InputText @bind-Value="_form.ImageUrl" class="form-control"
								   placeholder="Project.webp" disabled="@IsSaving" />
						<ValidationMessage For="@(() => _form.ImageUrl)" />
					</div>
					<div class="col-md-2">
						<label class="form-label">Order</label>
						<InputNumber @bind-Value="_form.Order" class="form-control"
									 disabled="@IsSaving" />
					</div>
				</div>

				<h6 class="mb-3">Translations</h6>

				@for (var i = 0; i < _form.Translations.Count; i++)
				{
					var index = i;
					var trans = _form.Translations[index];

					<div class="card mb-3">
						<div class="card-header py-2">
							<strong>@LanguageDisplayHelper.DisplayName(trans.Language)</strong>
						</div>
						<div class="card-body">
							<div class="mb-3">
								<label class="form-label">Name</label>
								<InputText @bind-Value="_form.Translations[index].Name"
										   class="form-control" disabled="@IsSaving" />
								<ValidationMessage For="@(() => _form.Translations[index].Name)" />
							</div>
							<div class="mb-3">
								<label class="form-label">Info <span class="text-muted fw-normal">(short tagline)</span></label>
								<InputText @bind-Value="_form.Translations[index].Info"
										   class="form-control" disabled="@IsSaving" />
							</div>
							<div class="mb-3">
								<MarkdownEditor @bind-Value="_form.Translations[index].Description"
												Label="Description"
												Rows="4"
												MinHeight="5"
												Disabled="@IsSaving" />
							</div>
						</div>
					</div>
				}

				@if (Keywords is not null && Keywords.Count > 0)
				{
					<h6 class="mb-3">Keywords</h6>

					@foreach (var group in Keywords.GroupBy(k => k.Type).OrderBy(g => g.Key))
					{
						<div class="mb-3">
							<strong class="small text-muted">@group.Key</strong>
							<div class="row mt-1">
								@foreach (var kw in group)
								{
									var kwId = kw.Id;
									var checkboxId = $"kw-{kwId}";
									var isChecked = _form.SelectedKeywordIds.Contains(kwId);

									<div class="col-md-4 col-lg-3">
										<div class="form-check">
											<input type="checkbox" id="@checkboxId"
												   class="form-check-input"
												   checked="@isChecked"
												   disabled="@IsSaving"
												   @onchange="(e) => ToggleKeyword(kwId, (bool)(e.Value ?? false))" />
											<label for="@checkboxId" class="form-check-label small">@kw.Name</label>
										</div>
									</div>
								}
							</div>
						</div>
					}
				}
			</EditForm>
		}
	</ChildContent>
	<FooterContent>
		<button type="button" class="btn btn-secondary"
				@onclick="OnCancel" disabled="@IsSaving">
			Cancel
		</button>
		<button type="button" class="btn btn-primary"
				@onclick="HandleSubmit" disabled="@IsSaving">
			@if (IsSaving)
			{
				<span class="spinner-border spinner-border-sm me-1"></span>
				<span>Saving…</span>
			}
			else
			{
				<span>@(Mode == ModalMode.Create ? "Create" : "Save Changes")</span>
			}
		</button>
	</FooterContent>
</ModalDialog>
