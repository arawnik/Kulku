@using Kulku.Application.Cover.Experience.Models

<div class="col-12">
    <div class="card shadow-sm">
        @if (Experience is not null)
        {
            var translations = Experience.Translations
                .OrderBy(t => t.Language.ToString()).ToList();
            var companyTranslations = Experience.CompanyTranslations;

            <div class="card-header d-flex justify-content-between align-items-start gap-3">
                <div>
                    <h5 class="mb-0 fw-semibold">
                        @(translations.FirstOrDefault()?.Title ?? "Untitled")
                    </h5>
                    @{
                        var primaryCompany = companyTranslations
                            .FirstOrDefault(c => c.Language == (translations.FirstOrDefault()?.Language ?? default));
                    }
                    <div class="text-muted small">
                        @(primaryCompany?.Name ?? "Unknown company")
                    </div>
                </div>
                <div class="text-end text-nowrap">
                    <div class="fw-semibold">
                        @Experience.StartDate.ToString("yyyy")–@(Experience.EndDate?.ToString("yyyy") ?? "Present")
                    </div>
                </div>
            </div>

            <div class="card-body">
                @if (translations.Count == 0)
                {
                    <div class="text-muted small">No translations available.</div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var trans in translations)
                        {
                            var comp = companyTranslations
                                .FirstOrDefault(c => c.Language == trans.Language);

                            <div class="@(translations.Count == 1 ? "col-12" : "col-12 col-md-6")">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge bg-secondary">
                                        @LanguageDisplayHelper.DisplayName(trans.Language)
                                    </span>
                                    <span class="fw-semibold small">@trans.Title</span>
                                </div>
                                @if (comp is not null && comp.Name != primaryCompany?.Name)
                                {
                                    <div class="text-muted small mb-1">@comp.Name</div>
                                }
                                <div class="text-muted small experience-description">
                                    @trans.Description
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                <button type="button" class="btn btn-link btn-sm edit-link p-0"
                        @onclick="HandleEditClick">
                    Click to edit
                </button>
                <small class="text-muted">
                    @translations.Count translation(s)
                </small>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ExperienceTranslationsModel? Experience { get; set; }

    [Parameter]
    public EventCallback<Guid> OnEdit { get; set; }

    private async Task HandleEditClick()
    {
        if (Experience is not null)
        {
            await OnEdit.InvokeAsync(Experience.ExperienceId);
        }
    }
}
