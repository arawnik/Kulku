@using Kulku.Application.Projects.Models
@using Kulku.Application.Abstractions.Assets

@inject IAssetUrlBuilder StaticAssets

<div class="col-12">
	<div class="card shadow-sm">
		@if (Project is not null)
		{
			var translations = Project.Translations
				.OrderBy(t => t.Language.ToString()).ToList();

			<div class="card-header d-flex justify-content-between align-items-start gap-3">
				<div class="d-flex align-items-center gap-3">
					<img src="@StaticAssets.Project(Project.ImageUrl)" alt="Project thumbnail"
						 class="project-thumbnail rounded"
						 onerror="this.style.display='none'" />
					<div>
						<h5 class="mb-0 fw-semibold">
							@(translations.FirstOrDefault()?.Name ?? "Untitled")
						</h5>
						<div class="text-muted small">
							@(translations.FirstOrDefault()?.Info ?? string.Empty)
						</div>
					</div>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge bg-secondary">Order: @Project.Order</span>
					<a href="@Project.Url" target="_blank" rel="noopener"
						   class="btn btn-sm btn-outline-secondary">
						Visit
					</a>
				</div>
			</div>

			<div class="card-body">
				@if (translations.Count == 0)
				{
					<div class="text-muted small">No translations available.</div>
				}
				else
				{
					<div class="row g-3">
						@foreach (var trans in translations)
						{
							<div class="@(translations.Count == 1 ? "col-12" : "col-12 col-md-6")">
								<div class="d-flex align-items-center gap-2 mb-2">
									<span class="badge bg-secondary">
										@LanguageDisplayHelper.DisplayName(trans.Language)
									</span>
									<span class="fw-semibold small">@trans.Name</span>
								</div>
								<div class="text-muted small mb-1">@trans.Info</div>
								@if (!string.IsNullOrEmpty(trans.Description))
								{
									<div class="text-muted small project-description">
										<MarkdownView Content="@trans.Description" />
									</div>
								}
							</div>
						}
					</div>
				}

				@if (KeywordNames.Count > 0)
				{
					<div class="mt-3 d-flex flex-wrap gap-1">
						@foreach (var kw in KeywordNames)
						{
							<span class="badge bg-light text-dark border">@kw</span>
						}
					</div>
				}
			</div>

			<div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
				<div class="d-flex align-items-center gap-2">
					<button type="button" class="btn btn-sm btn-outline-primary"
							@onclick="HandleEditClick">
						<Icon Kind="IconKind.Pencil" Size="14" CssClass="me-1" />Edit
					</button>
					<button type="button" class="btn btn-sm btn-outline-danger"
							@onclick="() => _confirmingDelete = true">
						<Icon Kind="IconKind.Trash" Size="14" CssClass="me-1" />Delete
					</button>
				</div>
				<small class="text-muted">
					@translations.Count translation(s)
				</small>
			</div>
		}
	</div>
</div>

<ConfirmDialog Visible="_confirmingDelete"
			   Title="Delete Project"
			   Message="Are you sure you want to delete this project? This action cannot be undone."
			   ButtonText="Delete"
			   ButtonStyle="danger"
			   ButtonIcon="IconKind.Trash"
			   OnConfirm="HandleConfirmDelete"
			   OnCancel="() => _confirmingDelete = false" />
