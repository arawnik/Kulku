@using System.ComponentModel.DataAnnotations
@using Kulku.Application.Cover.Models
@using Kulku.Domain
@using SoulNETLib.Clean.Domain

<ModalDialog Visible="@(_form != null)"
			 Title="@(Mode == ModalMode.Create ? "Create Institution" : "Edit Institution")"
			 Size="ModalSize.Default"
			 OnClose="OnCancel">
	<ChildContent>
		@if (ErrorMessage is not null)
		{
			<div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
		}
		@if (_form != null)
		{
			<EditForm EditContext="@_editContext">
				<DataAnnotationsValidator />
				<ServerValidation @ref="_serverValidation" />

				<h6 class="mb-3">Translations</h6>

				@for (var i = 0; i < _form.Translations.Count; i++)
				{
					var index = i;
					var trans = _form.Translations[index];

					<div class="card mb-3">
						<div class="card-header py-2">
							<strong>@LanguageDisplayHelper.DisplayName(trans.Language)</strong>
						</div>
						<div class="card-body">
							<div class="mb-3">
								<label class="form-label">Name</label>
								<InputText @bind-Value="_form.Translations[index].Name"
										   class="form-control" disabled="@IsSaving" />
								<ValidationMessage For="@(() => _form.Translations[index].Name)" />
							</div>
							<div class="mb-3">
								<label class="form-label">Department</label>
								<InputText @bind-Value="_form.Translations[index].Department"
										   class="form-control" disabled="@IsSaving"
										   placeholder="Optional" />
							</div>
							<div>
								<label class="form-label">Description</label>
								<InputTextArea @bind-Value="_form.Translations[index].Description"
											   class="form-control" rows="2" disabled="@IsSaving" />
							</div>
						</div>
					</div>
				}
			</EditForm>
		}
	</ChildContent>
	<FooterContent>
		<button type="button" class="btn btn-secondary"
				@onclick="OnCancel" disabled="@IsSaving">
			Cancel
		</button>
		<button type="button" class="btn btn-primary"
				@onclick="HandleSubmit" disabled="@IsSaving">
			@if (IsSaving)
			{
				<span class="spinner-border spinner-border-sm me-1"></span>
				<span>Saving…</span>
			}
			else
			{
				<span>@(Mode == ModalMode.Create ? "Create" : "Save Changes")</span>
			}
		</button>
	</FooterContent>
</ModalDialog>

@code {
	[Parameter, EditorRequired]
	public InstitutionTranslationsModel? Model { get; set; }

	[Parameter]
	public ModalMode Mode { get; set; } = ModalMode.Edit;

	[Parameter]
	public EventCallback<InstitutionTranslationsModel> OnSave { get; set; }

	[Parameter]
	public EventCallback OnCancel { get; set; }

	[Parameter]
	public bool IsSaving { get; set; }

	[Parameter]
	public string? ErrorMessage { get; set; }

	private InstitutionEditFormModel? _form;
	private EditContext? _editContext;
	private ServerValidation? _serverValidation;
	private Guid? _lastModelId;

	public void SetServerErrors(IEnumerable<Error> errors)
	{
		_serverValidation?.DisplayErrors(errors);
	}

	protected override void OnParametersSet()
	{
		if (Model is null)
		{
			_form = null;
			_editContext = null;
			_lastModelId = null;
			return;
		}

		if (_lastModelId != Model.InstitutionId)
		{
			_lastModelId = Model.InstitutionId;
			_form = new InstitutionEditFormModel
			{
				InstitutionId = Model.InstitutionId,
				Translations = Model.Translations
					.Select(t => new InstitutionTransEditModel
					{
						Language = t.Language,
						Name = t.Name,
						Department = t.Department ?? string.Empty,
						Description = t.Description,
					})
					.ToList(),
			};
			_editContext = new EditContext(_form);
			_editContext.SetFieldCssClassProvider(new BootstrapFieldCssClassProvider());
		}
	}

	private async Task HandleSubmit()
	{
		if (_form is null || Model is null || _editContext is null) return;
		if (!_editContext.Validate()) return;

		var updatedTranslations = _form.Translations
			.Select(t => new InstitutionTranslationItem(
				t.Language,
				t.Name,
				string.IsNullOrWhiteSpace(t.Department) ? null : t.Department,
				t.Description))
			.ToList();

		var updated = Model with { Translations = updatedTranslations };

		await OnSave.InvokeAsync(updated);
	}

	private sealed class InstitutionEditFormModel
	{
		public Guid InstitutionId { get; init; }
		public List<InstitutionTransEditModel> Translations { get; set; } = [];
	}

	private sealed class InstitutionTransEditModel
	{
		public LanguageCode Language { get; init; }

		[Required(ErrorMessage = "Name is required.")]
		public string Name { get; set; } = string.Empty;

		public string Department { get; set; } = string.Empty;

		public string Description { get; set; } = string.Empty;
	}
}
