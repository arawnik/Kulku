@using Kulku.Application.Projects.Models

@if (Keywords is not null && Keywords.Count > 0)
{
	<h6 class="mb-3">@Strings.Keywords</h6>

	@foreach (var group in Keywords.GroupBy(k => k.Type).OrderBy(g => g.Key))
	{
		<div class="mb-3">
			<strong class="small text-muted">@group.Key</strong>
			<div class="row mt-1">
				@foreach (var kw in group)
				{
					var kwId = kw.Id;
					var checkboxId = $"kw-{kwId}";
					var isChecked = SelectedKeywordIds.Contains(kwId);

					<div class="col-md-4 col-lg-3">
						<div class="form-check">
							<input type="checkbox" id="@checkboxId"
								   class="form-check-input"
								   checked="@isChecked"
								   disabled="@Disabled"
								   @onchange="(e) => ToggleKeyword(kwId, (bool)(e.Value ?? false))" />
							<label for="@checkboxId" class="form-check-label small">@kw.Name</label>
						</div>
					</div>
				}
			</div>
		</div>
	}
}
