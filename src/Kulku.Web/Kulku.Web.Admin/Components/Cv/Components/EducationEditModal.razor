@using System.ComponentModel.DataAnnotations
@using Kulku.Application.Cover.Education.Models
@using Kulku.Application.Cover.Models
@using Kulku.Domain
@using SoulNETLib.Clean.Domain

<ModalDialog Visible="@(_form != null)"
			 Title="@(Mode == ModalMode.Create ? CvStrings.Education_CreateModal : CvStrings.Education_EditModal)"
			 OnClose="OnCancel">
	<ChildContent>
		@if (ErrorMessage is not null)
		{
			<div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
		}
		@if (_form != null)
		{
			<EditForm EditContext="@_editContext">
				<DataAnnotationsValidator />
				<ServerValidation @ref="_serverValidation" />

				@if (Mode == ModalMode.Create && Institutions is not null)
				{
					<div class="mb-4">
						<label class="form-label">@Strings.Institution</label>
						<InputSelect @bind-Value="_form.InstitutionId" class="form-select"
									 disabled="@IsSaving">
							<option value="">@Strings.SelectInstitution</option>
							@foreach (var inst in Institutions)
							{
								var name = inst.Translations.FirstOrDefault()?.Name ?? "Unnamed";
								<option value="@inst.InstitutionId">@name</option>
							}
						</InputSelect>
						<ValidationMessage For="@(() => _form.InstitutionId)" />
					</div>
				}

				<div class="row g-3 mb-4">
					<div class="col-md-6">
						<label class="form-label">@Strings.StartDate</label>
						<InputDate @bind-Value="_form.StartDate" class="form-control"
								   disabled="@IsSaving" />
					</div>
					<div class="col-md-6">
						<label class="form-label">@Strings.EndDate <span class="text-muted fw-normal">@Strings.EmptyOngoing</span></label>
						<InputDate @bind-Value="_form.EndDate" class="form-control"
								   disabled="@IsSaving" />
						<ValidationMessage For="@(() => _form.EndDate)" />
					</div>
				</div>

				<h6 class="mb-3">@Strings.Translations</h6>

				@for (var i = 0; i < _form.Translations.Count; i++)
				{
					var index = i;
					var trans = _form.Translations[index];

					<div class="card mb-3">
						<div class="card-header py-2">
							<strong>@LanguageDisplayHelper.DisplayName(trans.Language)</strong>
						</div>
						<div class="card-body">
							<div class="mb-3">
								<label class="form-label">@Strings.Title</label>
								<InputText @bind-Value="_form.Translations[index].Title"
										   class="form-control" disabled="@IsSaving" />
								<ValidationMessage For="@(() => _form.Translations[index].Title)" />
							</div>
							<div>
								<label class="form-label">@Strings.Description</label>
								<InputTextArea @bind-Value="_form.Translations[index].Description"
											   class="form-control" rows="4"
											   disabled="@IsSaving" />
							</div>
						</div>
					</div>
				}
			</EditForm>
		}
	</ChildContent>
	<FooterContent>
		<button type="button" class="btn btn-secondary"
				@onclick="OnCancel" disabled="@IsSaving">
			@Strings.Cancel
		</button>
		<button type="button" class="btn btn-primary"
				@onclick="HandleSubmit" disabled="@IsSaving">
			@if (IsSaving)
			{
				<span class="spinner-border spinner-border-sm me-1"></span>
				<span>@Strings.Saving</span>
			}
			else
			{
				<span>@(Mode == ModalMode.Create ? Strings.Create : Strings.SaveChanges)</span>
			}
		</button>
	</FooterContent>
</ModalDialog>
