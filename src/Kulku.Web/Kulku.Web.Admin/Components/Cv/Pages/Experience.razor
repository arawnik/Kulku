@page "/cv/experience"
@using Kulku.Application.Cover.Experience.Models

<PageTitle>Experience — Admin</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h4 mb-1">Experience</h1>
            <div class="text-muted">Manage experience entries and translations</div>
        </div>
        <NavLink class="btn btn-sm btn-outline-secondary" href="/cv">Back</NavLink>
    </div>

    @if (!_loaded)
    {
        <div class="text-muted">Loading…</div>
    }
    else if (Experiences.Count <= 0)
    {
        <div class="alert alert-secondary">There are no experience entries.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var exp in Experiences)
            {
                <ExperienceCard Experience="exp" OnEdit="HandleEdit" />
            }
        </div>
    }

    @if (_errorMessage is not null && EditingExperienceId is null)
    {
        <div class="alert alert-danger mt-3">@_errorMessage</div>
    }
</div>

@if (EditingExperienceId != null && CurrentEditModel != null)
{
    <ExperienceEditModal @ref="_editModal"
        Model="CurrentEditModel"
        OnSave="HandleSave"
        OnCancel="HandleCancel"
        IsSaving="IsSaving"
        ErrorMessage="@_errorMessage"
    />
}
