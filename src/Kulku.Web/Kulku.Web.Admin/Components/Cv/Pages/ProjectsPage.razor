@page "/cv/projects"

<PageTitle>Projects</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h4 mb-1">Projects</h1>
            <div class="text-muted">Read view</div>
        </div>
        <NavLink class="btn btn-sm btn-outline-secondary" href="/cv">Back</NavLink>
    </div>

    @if (!_loaded)
    {
        <div class="text-muted">Loading…</div>
    }
    else
    {
        if (!ProjectsList.Any())
        {
            <div class="alert alert-secondary">There are no projects.</div>
        }
        else
        {
            <div class="row g-3">
				@foreach (var project in ProjectsList.OrderBy(p => p.Order))
                {
                    <div class="col-12 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="d-flex gap-3 align-items-start">
                                    <img src="@project.ImageUrl" class="rounded" style="width:96px;height:64px;object-fit:cover" alt="Project image" />
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h2 class="h5 mb-1">@project.Name</h2>
                                                <div class="text-muted">@project.Info</div>
                                            </div>
                                            <a class="btn btn-sm btn-outline-secondary" href="@project.Url" target="_blank">Visit</a>
                                        </div>

                                        @if (!string.IsNullOrEmpty(project.Description))
                                        {
                                            <div class="mt-2">@project.Description</div>
                                        }

                                        @if (project.Keywords?.Any() == true)
                                        {
                                            <div class="mt-3">
                                                <strong>Keywords</strong>
                                                <div class="d-flex flex-wrap gap-2 mt-2">
                                                    @foreach (var kw in project.Keywords.OrderBy(k => k.Order))
                                                    {
                                                        <span class="badge bg-light text-dark">@kw.Name</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
