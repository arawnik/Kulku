@page "/cv/introduction"
@using Kulku.Application.Cover.Introduction.Models
@attribute [Authorize]

<PageTitle>@CvStrings.Introduction_PageTitle</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex justify-content-between align-items-start mb-3">
		<div>
			<h1 class="h4 mb-1">@CvStrings.Introduction_Heading</h1>
			<div class="text-muted">@CvStrings.Introduction_Subtitle</div>
		</div>
		<div class="d-flex gap-2">
			<button type="button" class="btn btn-sm btn-outline-success" @onclick="HandleCreate">
				<Icon Kind="IconKind.Plus" CssClass="me-1" />@CvStrings.Introduction_Add
			</button>
			<NavLink class="btn btn-sm btn-outline-secondary" href="/cv">@Strings.Back</NavLink>
		</div>
	</div>

	@if (!_loaded)
	{
		<div class="text-muted">@Strings.Loading</div>
	}
	else if (_allIntroductions.Count <= 0)
	{
		<div class="alert alert-secondary">@CvStrings.Introduction_NoEntries</div>
	}
	else
	{
		@* ── Active ── *@
		@if (_active is not null)
		{
			<h5 class="mb-2">@CvStrings.Introduction_Active</h5>
			<div class="mb-4">
				<IntroductionCard Introduction="_active"
								  IsActive="true"
								  StatusLabel="@CvStrings.Introduction_Active"
								  OnEdit="HandleEdit"
								  OnDelete="HandleDelete" />
			</div>
		}

		@* ── Scheduled ── *@
		@if (_scheduled.Count > 0)
		{
			<h5 class="mb-2">@CvStrings.Introduction_Scheduled</h5>
			<div class="row g-3 mb-4">
				@foreach (var intro in _scheduled)
				{
					<div class="col-12">
						<IntroductionCard Introduction="intro"
										  StatusLabel="@CvStrings.Introduction_Scheduled"
										  OnEdit="HandleEdit"
										  OnDelete="HandleDelete" />
					</div>
				}
			</div>
		}

		@* ── History ── *@
		@if (_history.Count > 0)
		{
			<div class="mb-2">
				<button type="button" class="btn btn-sm btn-link text-muted p-0"
						@onclick="() => _showHistory = !_showHistory">
					<Icon Kind="@(_showHistory ? IconKind.ChevronDown : IconKind.ChevronRight)" Size="14" CssClass="me-1" />
					@CvStrings.Introduction_History (@_history.Count)
				</button>
			</div>
			@if (_showHistory)
			{
				<div class="row g-3">
					@foreach (var intro in _history)
					{
						<div class="col-12">
							<IntroductionCard Introduction="intro"
											  StatusLabel="@CvStrings.Introduction_Superseded"
											  OnEdit="HandleEdit"
											  OnDelete="HandleDelete" />
						</div>
					}
				</div>
			}
		}
	}

	@if (_errorMessage is not null && _modalMode is null)
	{
		<div class="alert alert-danger mt-3">@_errorMessage</div>
	}
</div>

@if (_modalMode is not null && CurrentEditModel != null)
{
	<IntroductionEditModal @ref="_editModal"
						   Model="CurrentEditModel"
						   Mode="_modalMode.Value"
						   OnSave="HandleSave"
						   OnCancel="HandleCancel"
						   IsSaving="IsSaving"
						   ErrorMessage="@_errorMessage" />
}
