@page "/cv/education"
@using Kulku.Application.Cover.Education.Models

<PageTitle>Education — Admin</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h4 mb-1">Education</h1>
            <div class="text-muted">Manage education entries and translations</div>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-success" @onclick="HandleCreate">
                <Icon Kind="IconKind.Plus" CssClass="me-1" />Add Education
            </button>
            <NavLink class="btn btn-sm btn-outline-secondary" href="/cv">Back</NavLink>
        </div>
    </div>

    @if (!_loaded)
    {
        <div class="text-muted">Loading…</div>
    }
    else if (Educations.Count <= 0)
    {
        <div class="alert alert-secondary">There are no education entries.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var edu in Educations)
            {
                <EducationCard Education="edu" OnEdit="HandleEdit" OnDelete="HandleDelete" />
            }
        </div>
    }

    @if (_errorMessage is not null && _modalMode is null)
    {
        <div class="alert alert-danger mt-3">@_errorMessage</div>
    }
</div>

@if (_modalMode is not null && CurrentEditModel != null)
{
    <EducationEditModal @ref="_editModal"
        Model="CurrentEditModel"
        Mode="_modalMode.Value"
        Institutions="_institutions"
        OnSave="HandleSave"
        OnCancel="HandleCancel"
        IsSaving="IsSaving"
        ErrorMessage="@_errorMessage"
    />
}
