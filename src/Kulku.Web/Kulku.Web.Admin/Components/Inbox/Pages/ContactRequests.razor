@page "/inbox"
@using Kulku.Application.Contacts.Models
@using Kulku.Domain.Contacts
@using Kulku.Web.Admin.Components.Inbox.Components

@attribute [Authorize]

<PageTitle>@InboxStrings.PageTitle</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">@InboxStrings.Heading</h1>
			<div class="text-muted">@InboxStrings.Subtitle</div>
		</div>
	</div>

	@* ── Status filter tabs ── *@
	<ul class="nav nav-tabs mb-3">
		<li class="nav-item">
			<button class="nav-link @(_statusFilter == ContactRequestStatus.New ? "active" : "")"
					@onclick="() => SetFilter(ContactRequestStatus.New)">
				@InboxStrings.Tab_New
				<span class="badge text-bg-primary ms-1">@_allRequests.Count(r => r.Status == ContactRequestStatus.New)</span>
			</button>
		</li>
		<li class="nav-item">
			<button class="nav-link @(_statusFilter == ContactRequestStatus.Promoted ? "active" : "")"
					@onclick="() => SetFilter(ContactRequestStatus.Promoted)">
				@InboxStrings.Tab_Promoted
				<span class="badge text-bg-success ms-1">@_allRequests.Count(r => r.Status == ContactRequestStatus.Promoted)</span>
			</button>
		</li>
		<li class="nav-item">
			<button class="nav-link @(_statusFilter == ContactRequestStatus.Spam ? "active" : "")"
					@onclick="() => SetFilter(ContactRequestStatus.Spam)">
				@InboxStrings.Tab_Spam
				<span class="badge text-bg-warning ms-1">@_allRequests.Count(r => r.Status == ContactRequestStatus.Spam)</span>
			</button>
		</li>
		<li class="nav-item">
			<button class="nav-link @(_statusFilter == ContactRequestStatus.Dismissed ? "active" : "")"
					@onclick="() => SetFilter(ContactRequestStatus.Dismissed)">
				@InboxStrings.Tab_Dismissed
				<span class="badge text-bg-secondary ms-1">@_allRequests.Count(r => r.Status == ContactRequestStatus.Dismissed)</span>
			</button>
		</li>
		<li class="nav-item">
			<button class="nav-link @(_statusFilter is null ? "active" : "")"
					@onclick="() => SetFilter(null)">
				@Strings.All
				<span class="badge text-bg-accent border ms-1">@_allRequests.Count</span>
			</button>
		</li>
	</ul>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="alert alert-danger py-2 small">@_errorMessage</div>
	}

	@* ── Request list ── *@
	@{
		var filtered = FilteredRequests;
	}

	@if (filtered.Count == 0)
	{
		<div class="text-muted text-center py-5">
			@if (_allRequests.Count == 0)
			{
				<div>@InboxStrings.NoRequests</div>
			}
			else
			{
				<div>@InboxStrings.NoMatch</div>
			}
		</div>
	}
	else
	{
		<div class="mb-2 text-muted small">
			@string.Format(InboxStrings.ShowingCount, filtered.Count)
		</div>

		@foreach (var request in filtered)
		{
			<ContactRequestCard Request="@request"
								OnPromote="HandlePromote"
								OnMarkSpam="HandleMarkSpam"
								OnDismiss="HandleDismiss" />
		}
	}
</div>

<PromoteContactRequestModal @ref="_promoteModal"
							IsVisible="@(_promoteRequest is not null)"
							Request="@_promoteRequest"
							EnrolledCompanies="@_enrolledCompanies"
							OnSave="HandlePromoteSave"
							OnCancel="ClosePromoteModal" />
