@using Kulku.Web.Admin.Components.Developer

<ModalDialog Visible="@IsVisible" Title="@(Mode == ModalMode.Create ? "New Contact" : "Edit Contact")"
			 Size="ModalSize.Default"
			 OnClose="OnCancel">
	<ChildContent>
		<EditForm Model="@Form" OnValidSubmit="HandleSave">
			<DataAnnotationsValidator />

			<div class="mb-3">
				<label class="form-label">Name</label>
				<InputText class="form-control" @bind-Value="Form.PersonName" />
			</div>

			<div class="mb-3">
				<label class="form-label">Title / Role</label>
				<InputText class="form-control" @bind-Value="Form.Title" />
			</div>

			<div class="row g-3 mb-3">
				<div class="col-md-6">
					<label class="form-label">Email</label>
					<InputText class="form-control" @bind-Value="Form.Email" />
				</div>
				<div class="col-md-6">
					<label class="form-label">Phone</label>
					<InputText class="form-control" @bind-Value="Form.Phone" />
				</div>
			</div>

			<div class="mb-3">
				<label class="form-label">LinkedIn URL</label>
				<InputText class="form-control" @bind-Value="Form.LinkedInUrl" />
			</div>

			<div class="d-flex gap-2">
				<button type="submit" class="btn btn-primary">
					@(Mode == ModalMode.Create ? "Create" : "Save changes")
				</button>
				<button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">Cancel</button>
			</div>
		</EditForm>
	</ChildContent>
</ModalDialog>
