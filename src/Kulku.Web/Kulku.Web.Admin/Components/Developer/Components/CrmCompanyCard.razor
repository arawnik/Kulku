@using Kulku.Web.Admin.Components.Developer

<div class="card mb-2">
	<div class="card-body py-2 px-3">
		<div class="d-flex justify-content-between align-items-start">
			<div class="flex-grow-1 me-2">
				<div class="d-flex align-items-center gap-2 mb-1">
					<span class="badge @StageBadgeClass(Company.Profile!.Stage)">@StageLabel(Company.Profile!.Stage)</span>
					@if (!string.IsNullOrWhiteSpace(Company.Region))
					{
						<small class="text-muted">@Company.Region</small>
					}
				</div>

				<h6 class="mb-1">
					<a href="/developer/companies/@Company.Id" class="text-decoration-none">@Company.Name</a>
				</h6>

				@if (Categories.Count > 0)
				{
					<div class="d-flex flex-wrap gap-1 mb-1">
						@foreach (var cat in Categories)
						{
							<span class="badge text-bg-@(cat.ColorToken ?? "secondary") bg-opacity-50 fw-normal">@cat.Name</span>
						}
					</div>
				}

				<div class="d-flex align-items-center gap-3 mt-1">
					@if (ContactCount > 0)
					{
						<small class="text-muted">
							<Icon Kind="IconKind.PersonLinesFill" Size="12" CssClass="me-1" />@ContactCount contact(s)
						</small>
					}
					@if (InteractionCount > 0)
					{
						<small class="text-muted">
							<Icon Kind="IconKind.ChatDots" Size="12" CssClass="me-1" />@InteractionCount interaction(s)
						</small>
					}
					@if (LastInteractionDate.HasValue)
					{
						<small class="@RecencyTextClass(LastInteractionDate.Value)">
							Last: @LastInteractionDate.Value.ToString("yyyy-MM-dd")
						</small>
					}
				</div>
			</div>

			<div class="d-flex gap-1 flex-shrink-0">
				<button class="btn btn-sm btn-outline-primary" title="Edit"
						@onclick="() => OnEdit.InvokeAsync(Company.Id)">
					<Icon Kind="IconKind.Pencil" Size="14" />
				</button>
				@if (!_confirmDelete)
				{
					<button class="btn btn-sm btn-outline-danger" title="Delete"
							@onclick="() => _confirmDelete = true">
						<Icon Kind="IconKind.Trash" Size="14" />
					</button>
				}
				else
				{
					<button class="btn btn-sm btn-danger" title="Confirm delete"
							@onclick="() => OnDelete.InvokeAsync(Company.Id)">
						<Icon Kind="IconKind.Check" Size="14" />
					</button>
					<button class="btn btn-sm btn-outline-secondary" title="Cancel"
							@onclick="() => _confirmDelete = false">
						✕
					</button>
				}
			</div>
		</div>
	</div>
</div>
