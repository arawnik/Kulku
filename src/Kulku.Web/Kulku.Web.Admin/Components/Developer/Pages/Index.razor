@page "/developer/"
@inject CrmProtoStore Store

@attribute [Authorize]

<PageTitle>CRM Dashboard</PageTitle>

<div class="container-fluid py-4">

	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
		<div>
			<h1 class="h3 mb-1">Developer CRM</h1>
			<div class="text-muted">
				Incoming-first, but track the whole relationship: inbound + outbound touchpoints over long time horizons.
			</div>
		</div>

		<div class="d-flex flex-wrap gap-2">
			<NavLink class="btn btn-sm btn-primary" href="developer/loginteraction">+ Log interaction</NavLink>
		</div>
	</div>

	<!-- KPIs -->
	<div class="row g-3 mb-4">
		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Companies tracked</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@Store.Companies.Count</div>
						<span class="badge text-bg-secondary">focus list</span>
					</div>
					<div class="text-muted small mt-2">Keep this small. Quality relationships only.</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Inbound (90d)</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@InboundTotal</div>
						<span class="badge text-bg-primary">signal</span>
					</div>
					<div class="text-muted small mt-2">Channel performance across your funnel.</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Outbound (90d)</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@OutboundTotal</div>
						<span class="badge text-bg-secondary">discipline</span>
					</div>
					<div class="text-muted small mt-2">Selective touches; avoid volume bias.</div>
				</div>
			</div>
		</div>

	</div>

	<!-- Top row: channel mix + next actions -->
	<div class="row g-3 mb-4">
		<div class="col-12 col-xl-7">
			<div class="card shadow-sm h-100">
				<div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
					<div>
						<strong>Channel mix</strong>
						<div class="text-muted small">Only channels with activity (last 90 days).</div>
					</div>
					<span class="badge text-bg-light border">last 90 days</span>
				</div>

				<div class="card-body">
					@if (ActiveChannelStats.Count == 0)
					{
						<div class="text-muted">No interactions in the last 90 days.</div>
					}
					else
					{
						<div class="row g-3">
							@foreach (var item in ActiveChannelStats)
							{
								<div class="col-12 col-md-6">
									<div class="border rounded p-3 h-100">
										<div class="d-flex justify-content-between align-items-start">
											<div>
												<div class="text-uppercase text-muted small mb-1">@item.Label</div>
												<div class="text-muted small">@item.Note</div>
											</div>
											<span class="badge text-bg-light border">@item.Total</span>
										</div>

										<div class="mt-3">
											<div class="d-flex justify-content-between">
												<span class="text-muted small">Inbound</span>
												<span class="badge text-bg-primary">@item.Inbound</span>
											</div>
											<div class="d-flex justify-content-between mt-2">
												<span class="text-muted small">Outbound</span>
												<span class="badge text-bg-secondary">@item.Outbound</span>
											</div>
										</div>

										@if (item.WarmIntros > 0)
										{
											<div class="mt-3">
												<span class="badge text-bg-success">Warm intros @item.WarmIntros</span>
											</div>
										}
									</div>
								</div>
							}
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					Channels with zero activity are hidden to keep the dashboard focused.
				</div>
			</div>
		</div>

		<div class="col-12 col-xl-5">
			<div class="card shadow-sm h-100">
				<div class="card-header d-flex justify-content-between align-items-center">
					<div>
						<strong>Next actions</strong>
						<div class="text-muted small">Time-bound, company-specific.</div>
					</div>
					@if (NextActions.Count > 0)
					{
						<span class="badge text-bg-warning">@NextActions.Count due</span>
					}
				</div>

				<div class="card-body">
					@if (NextActions.Count == 0)
					{
						<div class="text-muted">
							No upcoming actions. Either you’re done, or you’re not capturing next steps.
						</div>
					}
					else
					{
						<div class="list-group list-group-flush">
							@foreach (var a in NextActions)
							{
								<div class="list-group-item px-0">
									<div class="d-flex justify-content-between align-items-start">
										<div class="fw-semibold">@a.CompanyName</div>
										<span class="badge @DueBadge(a.Due)">@a.Due.ToString("yyyy-MM-dd")</span>
									</div>
									<div class="text-muted small">@a.Action</div>

									<div class="mt-2 d-flex flex-wrap gap-2">
										<span class="badge @(a.Direction == InteractionDirection.Inbound ? "text-bg-primary" : "text-bg-secondary")">@a.Direction</span>
										<span class="badge text-bg-light border">@ChannelLabel(a.Channel)</span>
										@if (a.IsWarmIntro)
										{
											<span class="badge text-bg-success">Warm intro</span>
										}
									</div>
								</div>
							}
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					Actions are the “commitment device” — keep them few and meaningful.
				</div>
			</div>
		</div>
	</div>

	<!-- Bottom row: interaction stream -->
	<div class="row g-3">
		<div class="col-12">
			<div class="card shadow-sm">
				<div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
					<div>
						<strong>Interaction stream</strong>
						<div class="text-muted small">All touchpoints (inbound + outbound), capped for signal.</div>
					</div>
					<span class="badge text-bg-light border">last 180 days</span>
				</div>

				<div class="card-body p-0">
					@if (StreamRows.Count == 0)
					{
						<div class="p-3 text-muted">No interactions in the last 180 days.</div>
					}
					else
					{
						<div class="table-responsive">
							<table class="table table-sm align-middle mb-0">
								<thead class="table-active">
									<tr>
										<th class="text-nowrap">Date</th>
										<th>Company</th>
										<th class="text-nowrap">Dir</th>
										<th class="text-nowrap">Channel</th>
										<th>Summary</th>
										<th class="text-nowrap">Warm</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var r in StreamRows)
									{
										<tr>
											<td class="text-nowrap">
												<span class="@RecencyTextClass(r.Date)">@r.Date.ToString("yyyy-MM-dd")</span>
											</td>
											<td>
												<div class="fw-semibold">@r.CompanyName</div>
												@if (!string.IsNullOrWhiteSpace(r.CategoryLine))
												{
													<div class="text-muted small">@r.CategoryLine</div>
												}
											</td>
											<td class="text-nowrap">
												<span class="badge @(r.Direction == InteractionDirection.Inbound ? "text-bg-primary" : "text-bg-secondary")">@r.Direction</span>
											</td>
											<td class="text-nowrap">
												<span class="badge text-bg-light border">@ChannelLabel(r.Channel)</span>
											</td>
											<td>
												<div class="text-muted small">@r.Summary</div>
												@if (!string.IsNullOrWhiteSpace(r.ReferralLine))
												{
													<div class="mt-1">
														<span class="badge text-bg-success">@r.ReferralLine</span>
													</div>
												}
											</td>
											<td class="text-nowrap">
												@if (r.IsWarmIntro)
												{
													<span class="badge text-bg-success">Yes</span>
												}
												else
												{
													<span class="badge text-bg-secondary">No</span>
												}
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					Stream is capped by design. This is not a “lead inbox”.
				</div>
			</div>
		</div>
	</div>
</div>

@code {
	private DateTime MixCutoff => DateTime.Today.AddDays(-90);
	private DateTime StreamCutoff => DateTime.Today.AddDays(-180);

	private int InboundTotal =>
		Store.Interactions.Count(i => i.Direction == InteractionDirection.Inbound && i.Date >= MixCutoff);

	private int OutboundTotal =>
		Store.Interactions.Count(i => i.Direction == InteractionDirection.Outbound && i.Date >= MixCutoff);

	// Channel mix
	private sealed record ChannelMixRow(
		InteractionChannel Channel,
		string Label,
		string Note,
		int Inbound,
		int Outbound,
		int WarmIntros)
	{
		public int Total => Inbound + Outbound;
	}

	private List<ChannelMixRow> ActiveChannelStats =>
		Enum.GetValues<InteractionChannel>()
			.Select(ch =>
			{
				var inbound = Store.Interactions.Count(i => i.Date >= MixCutoff && i.Channel == ch && i.Direction == InteractionDirection.Inbound);
				var outbound = Store.Interactions.Count(i => i.Date >= MixCutoff && i.Channel == ch && i.Direction == InteractionDirection.Outbound);
				var warm = Store.Interactions.Count(i => i.Date >= MixCutoff && i.Channel == ch && i.Direction == InteractionDirection.Inbound && i.IsWarmIntro);
				return new ChannelMixRow(ch, ChannelLabel(ch), ChannelNote(ch), inbound, outbound, warm);
			})
			.Where(r => r.Total > 0) // hide empty
			.OrderByDescending(r => r.Total)
			.ToList();

	// Next actions
	private sealed record NextActionRow(string CompanyName, string Action, DateTime Due, InteractionDirection Direction, InteractionChannel Channel, bool IsWarmIntro);

	private List<NextActionRow> NextActions =>
		Store.Interactions
			.Where(i => i.NextActionDue is not null)
			.Select(i =>
			{
				var company = Store.Companies.First(c => c.Id == i.CompanyId);
				return new NextActionRow(company.Name, i.NextAction ?? "(missing)", i.NextActionDue!.Value.Date, i.Direction, i.Channel, i.IsWarmIntro);
			})
			.OrderBy(a => a.Due)
			.Take(8)
			.ToList();

	// Stream
	private sealed record StreamRow(
		DateTime Date,
		string CompanyName,
		string? CategoryLine,
		InteractionDirection Direction,
		InteractionChannel Channel,
		string Summary,
		bool IsWarmIntro,
		string? ReferralLine
	);

	private List<StreamRow> StreamRows =>
		Store.Interactions
			.Where(i => i.Date >= StreamCutoff)
			.OrderByDescending(i => i.Date)
			.Take(16)
			.Select(i =>
			{
				var company = Store.Companies.First(c => c.Id == i.CompanyId);
				var categoryLine = BuildCategoryLine(company.CategoryIds);

				var referralLine = i.IsWarmIntro
					? $"{i.ReferredByRelation ?? "Warm"} intro: {i.ReferredByName ?? "(unspecified)"}"
					: null;

				return new StreamRow(i.Date.Date, company.Name, categoryLine, i.Direction, i.Channel, i.Summary, i.IsWarmIntro, referralLine);
			})
			.ToList();

	private string? BuildCategoryLine(IReadOnlyList<Guid> categoryIds)
	{
		if (categoryIds.Count == 0) return null;

		var names = categoryIds
			.Select(id => Store.GetCategory(id)?.Name)
			.Where(n => !string.IsNullOrWhiteSpace(n))
			.ToList();

		return names.Count == 0 ? null : string.Join(" • ", names);
	}

	// UI helpers
	private static string ChannelLabel(InteractionChannel ch) => ch switch
	{
		InteractionChannel.CvContactForm => "CV contact form",
		InteractionChannel.Email => "Email",
		InteractionChannel.Call => "Call",
		InteractionChannel.LinkedIn => "LinkedIn",
		_ => ch.ToString()
	};

	private static string ChannelNote(InteractionChannel ch) => ch switch
	{
		InteractionChannel.CvContactForm => "Always-on funnel; track quality.",
		InteractionChannel.Email => "Continuation of context; good for depth.",
		InteractionChannel.Call => "Strong signal; usually intent.",
		InteractionChannel.LinkedIn => "High noise; stay selective.",
		_ => ""
	};

	private static string RecencyTextClass(DateTime d)
	{
		var days = (DateTime.Today - d.Date).TotalDays;
		if (days <= 21) return "text-success";
		if (days <= 60) return "text-warning";
		return "text-danger";
	}

	private static string DueBadge(DateTime due)
	{
		var days = (due.Date - DateTime.Today).TotalDays;
		if (days < 0) return "text-bg-danger";
		if (days <= 7) return "text-bg-warning";
		return "text-bg-secondary";
	}
}
