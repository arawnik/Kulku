@page "/developer/"
@using Kulku.Web.Admin.Components.Developer.Components

@inject CrmService Crm
@inject CrmProtoStore Store

@attribute [Authorize]

<PageTitle>CRM Dashboard</PageTitle>

<div class="container-fluid py-4">

	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
		<div>
			<h1 class="h3 mb-1">Developer CRM</h1>
			<div class="text-muted">
				Incoming-first, but track the whole relationship: inbound + outbound touchpoints over long time horizons.
			</div>
		</div>

		<div class="d-flex flex-wrap gap-2">
			<NavLink class="btn btn-sm btn-outline-secondary" href="developer/companies">
				<Icon Kind="IconKind.Building" Size="14" CssClass="me-1" />Companies
			</NavLink>
			<NavLink class="btn btn-sm btn-primary" href="developer/loginteraction">
				<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />Log interaction
			</NavLink>
		</div>
	</div>

	<!-- KPIs -->
	<div class="row g-3 mb-4">
		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Companies tracked</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@_enrolledCount</div>
						<span class="badge text-bg-secondary">focus list</span>
					</div>
					<div class="text-muted small mt-2">Keep this small. Quality relationships only.</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Inbound (90d)</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@_inboundTotal</div>
						<span class="badge text-bg-primary">signal</span>
					</div>
					<div class="text-muted small mt-2">Channel performance across your funnel.</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Outbound (90d)</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@_outboundTotal</div>
						<span class="badge text-bg-secondary">discipline</span>
					</div>
					<div class="text-muted small mt-2">Selective touches; avoid volume bias.</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="card shadow-sm h-100">
				<div class="card-body">
					<div class="text-uppercase text-muted small mb-1">Actions due</div>
					<div class="d-flex align-items-baseline gap-2">
						<div class="h2 mb-0">@_nextActions.Count</div>
						@if (_overdueCount > 0)
						{
							<span class="badge text-bg-danger">@_overdueCount overdue</span>
						}
						else
						{
							<span class="badge text-bg-success">on track</span>
						}
					</div>
					<div class="text-muted small mt-2">Pending commitments across all companies.</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Pipeline summary -->
	<div class="card shadow-sm mb-4">
		<div class="card-body py-2">
			<div class="d-flex align-items-center gap-3 flex-wrap">
				<span class="small text-muted">Pipeline:</span>
				@foreach (var stage in Enum.GetValues<CompanyStage>())
				{
					var count = _companies.Count(c => c.Profile!.Stage == stage);
					<NavLink href="developer/companies" class="text-decoration-none">
						<span class="badge @CrmCompanyCard.StageBadgeClass(stage)">
							@CrmCompanyCard.StageLabel(stage) @count
						</span>
					</NavLink>
				}
			</div>
		</div>
	</div>

	<!-- Top row: channel mix + next actions -->
	<div class="row g-3 mb-4">
		<div class="col-12 col-xl-7">
			<div class="card shadow-sm h-100">
				<div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
					<div>
						<strong>Channel mix</strong>
						<div class="text-muted small">Only channels with activity (last 90 days).</div>
					</div>
					<span class="badge text-bg-light border">last 90 days</span>
				</div>

				<div class="card-body">
					@if (_activeChannelStats.Count == 0)
					{
						<div class="text-muted">No interactions in the last 90 days.</div>
					}
					else
					{
						<div class="row g-3">
							@foreach (var item in _activeChannelStats)
							{
								<div class="col-12 col-md-6">
									<div class="border rounded p-3 h-100">
										<div class="d-flex justify-content-between align-items-start">
											<div>
												<div class="text-uppercase text-muted small mb-1">@item.Label</div>
												<div class="text-muted small">@item.Note</div>
											</div>
											<span class="badge text-bg-light border">@item.Total</span>
										</div>

										<div class="mt-3">
											<div class="d-flex justify-content-between">
												<span class="text-muted small">Inbound</span>
												<span class="badge text-bg-primary">@item.Inbound</span>
											</div>
											<div class="d-flex justify-content-between mt-2">
												<span class="text-muted small">Outbound</span>
												<span class="badge text-bg-secondary">@item.Outbound</span>
											</div>
										</div>

										@if (item.WarmIntros > 0)
										{
											<div class="mt-3">
												<span class="badge text-bg-success">Warm intros @item.WarmIntros</span>
											</div>
										}
									</div>
								</div>
							}
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					Channels with zero activity are hidden to keep the dashboard focused.
				</div>
			</div>
		</div>

		<div class="col-12 col-xl-5">
			<div class="card shadow-sm h-100">
				<div class="card-header d-flex justify-content-between align-items-center">
					<div>
						<strong>Next actions</strong>
						<div class="text-muted small">Time-bound, company-specific.</div>
					</div>
					@if (_nextActions.Count > 0)
					{
						<span class="badge text-bg-warning">@_nextActions.Count due</span>
					}
				</div>

				<div class="card-body">
					@if (_nextActions.Count == 0)
					{
						<div class="text-muted">
							No upcoming actions. Either you’re done, or you’re not capturing next steps.
						</div>
					}
					else
					{
						<div class="list-group list-group-flush">
							@foreach (var a in _nextActions)
							{
								<div class="list-group-item px-0">
									<div class="d-flex justify-content-between align-items-start">
										<div class="fw-semibold">@a.CompanyName</div>
										<span class="badge @DueBadge(a.Due)">@a.Due.ToString("yyyy-MM-dd")</span>
									</div>
									<div class="text-muted small">@a.Action</div>

									<div class="mt-2 d-flex flex-wrap gap-2">
										<span class="badge @(a.Direction == InteractionDirection.Inbound ? "text-bg-primary" : "text-bg-secondary")">@a.Direction</span>
										<span class="badge text-bg-light border">@ChannelLabel(a.Channel)</span>
										@if (a.IsWarmIntro)
										{
											<span class="badge text-bg-success">Warm intro</span>
										}
									</div>
								</div>
							}
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					Actions are the “commitment device” — keep them few and meaningful.
				</div>
			</div>
		</div>
	</div>

	<!-- Bottom row: interaction stream -->
	<div class="row g-3">
		<div class="col-12">
			<div class="card shadow-sm">
				<div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
					<div>
						<strong>Interaction stream</strong>
						<div class="text-muted small">All touchpoints (inbound + outbound), capped for signal.</div>
					</div>
					<span class="badge text-bg-light border">last 180 days</span>
				</div>

				<div class="card-body p-2">
					@if (_streamInteractions.Count == 0)
					{
						<div class="p-3 text-muted">No interactions in the last 180 days.</div>
					}
					else
					{
						@foreach (var interaction in _streamInteractions)
						{
							var companyName = _companyNameCache.GetValueOrDefault(interaction.CompanyId, "Unknown");
							var contactName = interaction.ContactId.HasValue
							? Store.GetContact(interaction.ContactId.Value)?.PersonName
							: null;

							<InteractionCard Interaction="@interaction"
											 CompanyName="@companyName"
											 CompanyLink="@($"/developer/companies/{interaction.CompanyId}")"
											 ContactName="@contactName" />
						}
					}
				</div>

				<div class="card-footer text-muted small">
					Stream is capped by design. This is not a "lead inbox".
				</div>
			</div>
		</div>
	</div>
</div>
