@page "/developer/companies"
@using Kulku.Web.Admin.Components.Developer.Components

@inject CrmService Crm
@inject CrmProtoStore Store

@attribute [Authorize]

<PageTitle>Companies</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">Companies</h1>
			<div class="text-muted">Focus list — keep it small, quality relationships only.</div>
		</div>

		<div class="d-flex flex-wrap gap-2">
			<button class="btn btn-sm btn-primary" @onclick="HandleEnrollCompany">
				<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />Enroll Company
			</button>
			<div class="btn-group btn-group-sm" role="group">
				<button class="btn @(_viewMode == ViewMode.List ? "btn-primary" : "btn-outline-primary")"
						@onclick="() => _viewMode = ViewMode.List">
					<Icon Kind="IconKind.ListNested" Size="14" CssClass="me-1" />List
				</button>
				<button class="btn @(_viewMode == ViewMode.Pipeline ? "btn-primary" : "btn-outline-primary")"
						@onclick="() => _viewMode = ViewMode.Pipeline">
					<Icon Kind="IconKind.Kanban" Size="14" CssClass="me-1" />Pipeline
				</button>
			</div>
		</div>
	</div>

	@* ── Filters (list view only) ── *@
	@if (_viewMode == ViewMode.List)
	{
		<div class="row g-2 mb-3">
			<div class="col-md-3">
				<input type="text" class="form-control form-control-sm" placeholder="Search…"
					   @bind="_searchText" @bind:event="oninput" />
			</div>
			<div class="col-md-2">
				<select class="form-select form-select-sm" @bind="_filterStage">
					<option value="">All Stages</option>
					@foreach (var s in Enum.GetValues<CompanyStage>())
					{
						<option value="@s">@CrmCompanyCard.StageLabel(s)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<select class="form-select form-select-sm" @bind="_filterCategoryId">
					<option value="@Guid.Empty">All Categories</option>
					@foreach (var c in Store.Categories.OrderBy(c => c.Name))
					{
						<option value="@c.Id">@c.Name</option>
					}
				</select>
			</div>
		</div>
	}

	@* ── Content ── *@
	@if (_viewMode == ViewMode.List)
	{
		var filtered = FilteredCompanies;
		if (filtered.Count == 0)
		{
			<div class="text-muted text-center py-4">
				@(_companies.Count == 0
					? "No companies tracked yet."
					: "No companies match the current filters.")
			</div>
		}
		else
		{
			@foreach (var company in filtered)
			{
				var contacts = Store.GetCompanyContacts(company.Id);
				var interactions = Store.GetCompanyInteractions(company.Id);
				var categories = company.Profile!.CategoryIds
					.Select(id => Store.GetCategory(id))
					.Where(c => c is not null)
					.Cast<CategoryLite>()
					.ToList();

				<CrmCompanyCard Company="@company"
								Categories="@categories"
								ContactCount="@contacts.Count"
								InteractionCount="@interactions.Count"
								LastInteractionDate="@interactions.Select(i => (DateTime?)i.Date).FirstOrDefault()"
								OnEdit="HandleEditCompany"
								OnDelete="HandleDeleteCompany" />
			}
		}
	}
	else
	{
		<div class="row g-3">
			@foreach (var stage in Enum.GetValues<CompanyStage>())
			{
				<div class="col-12 col-md-6 col-xl-2">
					<PipelineColumn Stage="@stage" Companies="@GetPipelineItems(stage)" />
				</div>
			}
		</div>
	}

	@* ── Categories section (collapsible) ── *@
	<div class="mt-4">
		<div class="d-flex align-items-center gap-2 mb-2 cursor-pointer"
			 @onclick="() => _categoriesExpanded = !_categoriesExpanded">
			<Icon Kind="@(_categoriesExpanded? IconKind.ChevronDown: IconKind.ChevronRight)" Size="16" />
			<h5 class="mb-0">Categories</h5>
			<span class="badge bg-secondary">@Store.Categories.Count</span>
		</div>

		@if (_categoriesExpanded)
		{
			<div class="mb-2">
				<button class="btn btn-outline-primary btn-sm" @onclick="HandleCreateCategory">
					<Icon Kind="IconKind.Plus" Size="14" CssClass="me-1" />New Category
				</button>
			</div>

			@if (Store.Categories.Count == 0)
			{
				<p class="text-muted">No categories yet.</p>
			}
			else
			{
				@foreach (var cat in Store.Categories.OrderBy(c => c.Name))
				{
					<CategoryCard Category="@cat" OnEdit="HandleEditCategory" OnDelete="HandleDeleteCategory" />
				}
			}
		}
	</div>
</div>

@* ── Modals ── *@
<CrmCompanyEditModal @ref="_companyModal"
					 IsVisible="@(_companyMode is not null)"
					 Mode="@(_companyMode ?? ModalMode.Edit)"
					 Categories="@Store.Categories"
					 AvailableCompanies="@_availableCompanies"
					 OnSave="HandleSaveCompany"
					 OnCancel="CloseCompanyEditor" />

<CrmCategoryEditModal @ref="_categoryModal"
					  IsVisible="@(_categoryMode is not null)"
					  Mode="@(_categoryMode ?? ModalMode.Create)"
					  OnSave="HandleSaveCategory"
					  OnCancel="CloseCategoryEditor" />
