@page "/developer/ideas"
@inject CrmProtoStore Store
@inject NavigationManager Nav

<PageTitle>Idea Bank</PageTitle>

<div class="container-fluid py-4">
	<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
		<div>
			<h1 class="h4 mb-1">Idea Bank</h1>
			<div class="text-muted">
				Capture design thoughts before they become backlog tickets.
				Link to prospects when it helps validation.
			</div>
		</div>

		<div class="d-flex gap-2">
			<NavLink class="btn btn-sm btn-primary" href="developer/ideas/new">+ New idea</NavLink>
		</div>
	</div>

	<div class="row g-3 mb-3">
		<div class="col-12 col-lg-4">
			<div class="card shadow-sm">
				<div class="card-header">
					<strong>Filters</strong>
				</div>
				<div class="card-body">
					<div class="mb-3">
						<label class="form-label">Status</label>
						<select class="form-select" @bind="StatusFilter">
							<option value="">All</option>
							@foreach (var s in Enum.GetValues<IdeaStatus>())
							{
								<option value="@s">@s</option>
							}
						</select>
					</div>

					<div class="mb-3">
						<label class="form-label">Category</label>
						<select class="form-select" @bind="CategoryFilterId">
							<option value="">All</option>
							@foreach (var c in Store.Categories.OrderBy(c => c.Name))
							{
								<option value="@c.Id">@c.Name</option>
							}
						</select>
					</div>

					<div class="mb-0">
						<label class="form-label">Search</label>
						<input class="form-control" placeholder="Title / keywords" @bind="SearchText" />
					</div>
				</div>

				<div class="card-footer text-muted small">
					Keep the list curated. Park or promote aggressively.
				</div>
			</div>
		</div>

		<div class="col-12 col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
					<div>
						<strong>Ideas</strong>
						<div class="text-muted small">@FilteredIdeas.Count item(s)</div>
					</div>
					<span class="badge text-bg-light border">prototype</span>
				</div>

				<div class="card-body p-0">
					@if (FilteredIdeas.Count == 0)
					{
						<div class="p-3 text-muted">No ideas match filters.</div>
					}
					else
					{
						<div class="table-responsive">
							<table class="table table-sm align-middle mb-0">
								<thead class="table-light">
									<tr>
										<th>Title</th>
										<th class="text-nowrap">Status</th>
										<th class="text-nowrap">Scores</th>
										<th>Categories</th>
										<th class="text-nowrap">Linked</th>
										<th class="text-nowrap text-end"></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var idea in FilteredIdeas)
									{
										<tr>
											<td style="min-width: 240px;">
												<div class="fw-semibold">@idea.Title</div>
												@if (!string.IsNullOrWhiteSpace(idea.OneLiner))
												{
													<div class="text-muted small">@idea.OneLiner</div>
												}
											</td>

											<td class="text-nowrap">
												<span class="badge @IdeaStatusBadge(idea.Status)">@idea.Status</span>
											</td>

											<td class="text-nowrap">
												<span class="badge text-bg-dark">V @idea.ValueScore</span>
												<span class="badge text-bg-secondary ms-1">F @idea.FeasibilityScore</span>
											</td>

											<td>
												@foreach (var cat in ResolveCategories(idea.CategoryIds))
												{
													<span class="badge text-bg-light border me-1 mb-1">@cat.Name</span>
												}
											</td>

											<td class="text-nowrap">
												@if (idea.LinkedCompanyIds.Count == 0)
												{
													<span class="text-muted small">—</span>
												}
												else
												{
													<span class="badge text-bg-success">@idea.LinkedCompanyIds.Count</span>
												}
											</td>

											<td class="text-end text-nowrap">
												<NavLink class="btn btn-sm btn-outline-secondary" href="@($"developer/ideas/{idea.Id}")">
													Edit
												</NavLink>
											</td>
										</tr>

										@if (idea.LinkedCompanyIds.Count > 0)
										{
											<tr class="table-light">
												<td colspan="6">
													<div class="text-muted small">
														Linked companies:
														@string.Join(", ", ResolveCompanyNames(idea.LinkedCompanyIds))
													</div>
												</td>
											</tr>
										}
									}
								</tbody>
							</table>
						</div>
					}
				</div>

				<div class="card-footer text-muted small">
					“Linked” is for validation: who benefits, who can give feedback, who signals demand.
				</div>
			</div>
		</div>
	</div>
</div>

@code {
	private string? StatusFilter;
	private string? CategoryFilterId;
	private string? SearchText;

	private List<IdeaLite> FilteredIdeas =>
		Store.Ideas
			.Where(MatchesStatus)
			.Where(MatchesCategory)
			.Where(MatchesSearch)
			.OrderByDescending(i => (i.ValueScore * 10) + i.FeasibilityScore)
			.ThenByDescending(i => i.UpdatedAt)
			.ToList();

	private bool MatchesStatus(IdeaLite i)
		=> string.IsNullOrWhiteSpace(StatusFilter) || i.Status.ToString() == StatusFilter;

	private bool MatchesCategory(IdeaLite i)
	{
		if (string.IsNullOrWhiteSpace(CategoryFilterId)) return true;
		if (!Guid.TryParse(CategoryFilterId, out var id)) return true;
		return i.CategoryIds.Contains(id);
	}

	private bool MatchesSearch(IdeaLite i)
	{
		if (string.IsNullOrWhiteSpace(SearchText)) return true;
		var s = SearchText.Trim().ToLowerInvariant();
		return (i.Title?.ToLowerInvariant().Contains(s) ?? false)
			|| (i.OneLiner?.ToLowerInvariant().Contains(s) ?? false)
			|| (i.Description?.ToLowerInvariant().Contains(s) ?? false);
	}

	private IReadOnlyList<CategoryLite> ResolveCategories(IReadOnlyList<Guid> ids)
		=> ids.Select(id => Store.GetCategory(id))
			  .Where(c => c is not null)
			  .Cast<CategoryLite>()
			  .ToList();

	private IReadOnlyList<string> ResolveCompanyNames(IReadOnlyList<Guid> ids)
		=> ids.Select(id => Store.GetCompany(id)?.Name)
			  .Where(n => !string.IsNullOrWhiteSpace(n))
			  .Cast<string>()
			  .ToList();

	private static string IdeaStatusBadge(IdeaStatus status) => status switch
	{
		IdeaStatus.Seed => "text-bg-secondary",
		IdeaStatus.Exploring => "text-bg-info",
		IdeaStatus.Validating => "text-bg-warning",
		IdeaStatus.Parked => "text-bg-dark",
		IdeaStatus.PromotedToBacklog => "text-bg-success",
		_ => "text-bg-light"
	};
}
